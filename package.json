{
  "name": "clawmux-lite",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cmx": "./cli.js"
  },
  "scripts": {
    "start": "npm run build && node server.js",
    "dev": "concurrently -n server,vite -c cyan,magenta -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "CLAWMUX_DEV=1 node server.js",
    "dev:client": "cd app && npm run dev",
    "build": "cd app && npm run build",
    "update": "git pull && npm install && cd app && npm install && npm run build",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "npx playwright test",
    "test:ui": "npx playwright test tests/ui.spec.js --project=desktop",
    "test:mobile": "npx playwright test tests/ui.spec.js --project=mobile",
    "test:visual": "npx playwright test --update-snapshots",
    "test:report": "npx playwright show-report"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.126",
    "@opencode-ai/sdk": "^1.4.6",
    "express": "^5.2.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "prettier": "^3.8.2",
    "vite": "^8.0.3"
  }
}
