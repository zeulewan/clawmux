        found = None
        for s in sessions:
            name = s.get("voice", "").replace("af_", "").replace("am_", "").replace("bm_", "")
            if name == args.agent or s.get("voice") == args.agent or s.get("session_id") == args.agent:
                found = s
                break
        if not found:
            die(f"no session found for '{args.agent}'")

        print(f"Agent: {found.get('label', found.get('voice', '?'))}")
        print(f"  Voice: {found.get('voice', '?')}")
        print(f"  Status: {found.get('status', '?')}")
        print(f"  Session ID: {found.get('session_id', '?')}")
        if found.get("project"):
            area = f" · {found['project_area']}" if found.get("project_area") else ""
            print(f"  Project: {found['project']}{area}")
        if found.get("work_dir"):
            print(f"  Work dir: {found['work_dir']}")
        if found.get("model"):
            print(f"  Model: {found['model']}")
