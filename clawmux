#!/home/zeul/GIT/clawmux/.venv/bin/python3
"""ClawMux CLI — voice and inter-agent messaging.

Simple shell commands that any agent runtime can call.
Connect, do one thing, print the result, exit.

Env vars:
    CLAWMUX_SESSION_ID — session ID (required for send/wait/ack/reply)
    CLAWMUX_PORT       — hub port (default 3460)
"""

import argparse
import asyncio
import json
import os
import signal
import subprocess
import sys
import time

HUB_PORT = int(os.environ.get("CLAWMUX_PORT", "3460"))
HUB_BASE = f"http://127.0.0.1:{HUB_PORT}"
SESSION_ID = os.environ.get("CLAWMUX_SESSION_ID", "")


def _find_repo_dir() -> str:
    """Find the ClawMux repo directory reliably.

    Strategy: use sys.executable (the venv python from the shebang) to derive
    the repo root.  Falls back to __file__ location, then common paths.
    """
    # 1. sys.executable points to .venv/bin/python inside the repo
    exe = os.path.realpath(sys.executable)
    venv_bin = os.path.dirname(exe)  # .../repo/.venv/bin
    if os.path.basename(os.path.dirname(venv_bin)) == ".venv":
        candidate = os.path.dirname(os.path.dirname(venv_bin))
        if os.path.isdir(os.path.join(candidate, "server")):
            return candidate

    # 2. __file__ — works when running from repo directly
    script_dir = os.path.dirname(os.path.realpath(__file__))
    if os.path.isdir(os.path.join(script_dir, "server")):
        return script_dir

    # 3. Common install paths
    for candidate in [os.path.expanduser("~/GIT/clawmux"), os.path.expanduser("~/clawmux")]:
        if os.path.isdir(os.path.join(candidate, "server")):
            return candidate

    die("Cannot find ClawMux repo directory")
    return ""  # unreachable

