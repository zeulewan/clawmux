def _monitor_sessions_from_agents_json(project_slug):
    """Try to read agent sessions from data/agents.json.

    Returns a list of session dicts matching the /api/sessions format,
    or None if agents.json is missing/empty/unreadable.
    """
    try:
        repo_dir = _find_repo_dir()
    except SystemExit:
        return None

    agents_file = os.path.join(repo_dir, "data", "agents.json")
    if not os.path.isfile(agents_file):
        return None

    try:
        with open(agents_file) as f:
            data = json.load(f)
    except (json.JSONDecodeError, OSError):
        return None

    agents = data.get("agents", {})
    if not agents:
        return None

    # Build session list in the same format cmd_monitor expects
    # Also verify tmux sessions actually exist
    result = []
    for voice_id, entry in agents.items():
        if entry.get("project") != project_slug and project_slug != "default":
            continue
        session_id = entry.get("session_id")
        if not session_id:
            continue
        # Derive tmux session name — check both old and new naming conventions
        # Old: voice-{project}-{name}, New: just {name}
        name = voice_id.replace("af_", "").replace("am_", "").replace("bm_", "").replace("bf_", "")
        # Check which tmux session exists
        tmux_session = None
        for candidate in [name, f"voice-{project_slug}-{name}", f"clawmux-{name}"]:
            check = subprocess.run(["tmux", "has-session", "-t", f"={candidate}"],
                                   capture_output=True)
            if check.returncode == 0:
                tmux_session = candidate
                break
        if not tmux_session:
            continue
        result.append({
            "session_id": session_id,
            "tmux_session": tmux_session,
            "voice": voice_id,
            "label": name.capitalize(),
            "project_slug": entry.get("project", "default"),
            "project": entry.get("project", ""),
            "project_area": entry.get("area", ""),
            "status_text": "",
        })

    return result if result else None


def cmd_monitor(args):
    """Open a tmux session with a grid of panes showing all agent sessions."""
    import math

    # Determine project slug to monitor (active project if not specified)
    if args.project:
        project_slug = args.project
    else:
        projects_data = http_get("/api/projects")
        project_slug = projects_data.get("active_project") or "default"
    suffix = f"-{project_slug}" if project_slug != "default" else ""
    MONITOR_SESSION = f"clawmux-monitor{suffix}"

    # Kill existing monitor session if --restart
    if args.restart:
        subprocess.run(["tmux", "kill-session", "-t", f"={MONITOR_SESSION}"],
                       capture_output=True)

    # Check if monitor session already exists (= prefix forces exact match)
    check = subprocess.run(
        ["tmux", "has-session", "-t", f"={MONITOR_SESSION}"],
        capture_output=True,
    )
    if check.returncode == 0:
        if args.detach:
            print(f"Monitor session '{MONITOR_SESSION}' already exists.")
        else:
            print(f"Attaching to existing monitor session...")
            os.execlp("tmux", "tmux", "attach", "-t", f"={MONITOR_SESSION}")
        return

    # Get active sessions — try agents.json first, fall back to API
    agent_sessions = _monitor_sessions_from_agents_json(project_slug)
    if agent_sessions is None:
        sessions = http_get("/api/sessions")
        agent_sessions = [
            s for s in sessions
            if s.get("tmux_session") and s.get("project_slug", "default") == project_slug
        ]

    if not agent_sessions:
        die(f"no active agent sessions for project '{project_slug}'")

    # Filter by names if specified
    if args.agents:
        names = [n.lower() for n in args.agents]
        agent_sessions = [
            s for s in agent_sessions
            if s.get("label", "").lower() in names
            or s.get("tmux_session", "").replace("voice-", "") in names
        ]
        if not agent_sessions:
            die(f"no matching sessions for: {', '.join(args.agents)}")

    # Sort by label for consistent ordering
    agent_sessions.sort(key=lambda s: s.get("label", ""))
    n = len(agent_sessions)

    print(f"Creating monitor grid with {n} panes...")

    # Dynamic grid layout: cols = ceil(sqrt(n)), rows = ceil(n/cols)
    # For 9 agents → 3x3, for 7 → 3x3 (last col partial), for 4 → 2x2
    if n <= 3:
        cols = n
        rows = 1
    else:
        cols = math.ceil(math.sqrt(n))
        rows = math.ceil(n / cols)

    def attach_cmd(session_name):
        """Build a command to interactively attach to an agent's tmux session.
        Uses a reconnect loop so the pane survives agent session restarts (e.g. hub reloads)."""
        return f"while true; do TMUX= tmux attach -t {session_name} 2>/dev/null || sleep 2; done"

    def tmux_run(*cmd_args, **kwargs):
        return subprocess.run(["tmux"] + list(cmd_args),
                              capture_output=True, text=True, **kwargs)

    def split_pane(target, direction, cmd=None):
        """Split a pane and return the new pane's %id."""
        split_args = ["tmux", "split-window", "-t", target, direction,
                      "-P", "-F", "#{pane_id}"]
        if cmd:
            split_args.append(cmd)
        result = subprocess.run(split_args, capture_output=True, text=True, check=True)
        return result.stdout.strip()

    # Create monitor session — returns first pane id
    result = subprocess.run([
        "tmux", "new-session", "-d", "-s", MONITOR_SESSION,
        "-x", "240", "-y", "60",
        "-P", "-F", "#{pane_id}",
    ], capture_output=True, text=True, check=True)
    first_pane = result.stdout.strip()

    # Collect pane IDs mapped to agents
    pane_map = []  # [(pane_id, agent)]

    if n == 1:
        pane_map.append((first_pane, agent_sessions[0]))
    elif rows == 1:
        # Single row: 1-3 agents as columns
        pane_map.append((first_pane, agent_sessions[0]))
        for s in agent_sessions[1:]:
            pid = split_pane(first_pane, "-h")
            pane_map.append((pid, s))
        tmux_run("select-layout", "-t", MONITOR_SESSION, "even-horizontal")
    else:
        # Multi-row grid: create columns, then split each into rows
        # Create columns by splitting horizontally
        col_panes = [first_pane]
        for i in range(1, cols):
            pid = split_pane(col_panes[-1], "-h")
            col_panes.append(pid)
        tmux_run("select-layout", "-t", MONITOR_SESSION, "even-horizontal")

        agent_idx = 0
        for i, col_pane in enumerate(col_panes):
            # How many agents in this column
            remaining = n - agent_idx
            remaining_cols = cols - i
            col_count = math.ceil(remaining / remaining_cols)

            # First agent in column uses the existing pane
            pane_map.append((col_pane, agent_sessions[agent_idx]))
            agent_idx += 1

            # Split vertically for additional rows in this column
            for r in range(1, col_count):
                pid = split_pane(col_pane, "-v")
                pane_map.append((pid, agent_sessions[agent_idx]))
                agent_idx += 1

        # Re-tile to equalize pane sizes
        tmux_run("select-layout", "-t", MONITOR_SESSION, "tiled")

    # Agent signature colors (tmux colour codes)
    AGENT_COLORS = {
        # Project 1 (default/clawmux)
        "af_sky": "colour33",      # blue
        "af_alloy": "colour208",   # orange
        "af_sarah": "colour196",   # red
        "am_adam": "colour78",     # green
        "am_echo": "colour134",    # purple
        "am_onyx": "colour245",    # grey
        "bm_fable": "colour220",   # yellow
        "af_nova": "colour213",    # pink
        "am_eric": "colour39",     # cyan
        # Project 2 (hn-app)
        "af_bella": "colour171",   # lavender
        "af_jessica": "colour209",  # coral
        "af_heart": "colour204",   # rose
        "am_michael": "colour70",  # forest green
        "am_liam": "colour67",     # steel blue
        "am_fenrir": "colour130",  # brown
        "bf_emma": "colour174",    # salmon
        "bm_george": "colour109",  # teal
        "bm_daniel": "colour137",  # tan
        # Project 3
        "af_aoede": "colour183",   # light purple
        "af_jadzia": "colour117",  # light blue
        "af_kore": "colour168",    # magenta
        "af_nicole": "colour216",  # peach
        "af_river": "colour73",    # aqua
        "am_puck": "colour142",    # olive
        "bf_alice": "colour182",   # mauve
        "bf_lily": "colour223",    # cream
        "bm_lewis": "colour101",   # khaki
    }

    # Launch agent attach in each pane, label it, and set status bar color
    for pane_id, agent in pane_map:
        tmux_run("send-keys", "-t", pane_id,
                 attach_cmd(agent["tmux_session"]), "Enter")
        label = agent.get("label", agent["tmux_session"])
        tmux_run("select-pane", "-t", pane_id, "-T", label)
        tmux_run("set-option", "-p", "-t", pane_id, "@agent-label", label)

        # Set the agent's tmux session status bar to their signature color
        voice = agent.get("voice", "")
        color = AGENT_COLORS.get(voice)
        if color:
            _apply_agent_status_bar(agent["tmux_session"], label, color, voice=voice)

    # Get project display name for status bar
    projects_data = http_get("/api/projects")
    proj_info = projects_data.get("projects", {})
    proj_display = proj_info.get(project_slug, {}).get("name", project_slug)

    # Configure monitor session appearance
    for opt, val in [
        ("pane-border-status", "off"),
        ("pane-border-style", "fg=colour240"),
        ("pane-active-border-style", "fg=colour250"),
        ("status", "on"),
        ("status-position", "bottom"),
        ("status-style", "fg=colour255,bg=colour236"),
        ("status-left", f"  {proj_display} "),
        ("status-left-style", "fg=colour255,bg=colour236,bold"),
        ("status-left-length", "30"),
        ("status-right", f" {n} agents "),
        ("status-right-style", "fg=colour245,bg=colour236"),
        ("status-right-length", "20"),
        ("window-status-current-format", ""),
        ("window-status-format", ""),
    ]:
        tmux_run("set-option", "-t", MONITOR_SESSION, opt, val)

    agents_list = ", ".join(s.get("label", "?") for s in agent_sessions)
    print(f"Monitor ready: {agents_list}")

    # Start live watcher (auto-updates panes as agents join/leave)
    if not args.no_live:
        _start_monitor_watcher(MONITOR_SESSION, AGENT_COLORS, args.agents, project_slug)

    if not args.detach:
        os.execlp("tmux", "tmux", "attach", "-t", MONITOR_SESSION)


def _start_monitor_watcher(monitor_session, agent_colors, filter_agents, project_slug="default"):
    """Spawn a background process that keeps the monitor in sync with active sessions."""

    script = f'''
import json, subprocess, sys, time, urllib.request

MONITOR = {monitor_session!r}
COLORS = {agent_colors!r}
FILTER = {filter_agents!r}
PROJECT_SLUG = {project_slug!r}
HUB = "http://127.0.0.1:{HUB_PORT}"

def log(msg):
    print(msg, flush=True)

def get_sessions():
    try:
        with urllib.request.urlopen(HUB + "/api/sessions", timeout=5) as r:
            sessions = json.loads(r.read())
    except Exception as e:
        log(f"Hub error: {{e}}")
        return None
    result = [s for s in sessions if s.get("tmux_session") and s.get("project_slug", "default") == PROJECT_SLUG]
    if FILTER:
        names = [n.lower() for n in FILTER]
        result = [s for s in result if s.get("label","").lower() in names
                  or s.get("tmux_session","").replace("voice-","") in names]
    result.sort(key=lambda s: s.get("label",""))
    return result

def get_pane_map():
    """Return {{label: pane_id}} dict from current monitor panes.
    Uses @agent-label user option (immune to inner-session title overrides)."""
    r = subprocess.run(["tmux","list-panes","-t",MONITOR,"-F","#{{pane_id}} #{{@agent-label}}"],
                       capture_output=True, text=True)
    if r.returncode != 0:
        return None
    panes = {{}}
    for line in r.stdout.strip().splitlines():
        parts = line.split(" ", 1)
        if len(parts) == 2 and parts[1].strip():
            panes[parts[1].strip()] = parts[0]
    return panes

def any_pane_id():
    """Return any valid pane id from the monitor (used as split target)."""
    r = subprocess.run(["tmux","list-panes","-t",MONITOR,"-F","#{{pane_id}}"],
                       capture_output=True, text=True)
    if r.returncode != 0 or not r.stdout.strip():
        return None
    return r.stdout.strip().splitlines()[0]

def get_pane_order():
    """Return [(pane_id, label)] in current tmux pane index order."""
    r = subprocess.run(["tmux","list-panes","-t",MONITOR,"-F","#{{pane_id}} #{{@agent-label}}"],
                       capture_output=True, text=True)
    if r.returncode != 0:
        return None
    result = []
    for line in r.stdout.strip().splitlines():
        parts = line.split(" ", 1)
        if len(parts) == 2 and parts[1].strip():
            result.append((parts[0], parts[1].strip()))
    return result

def reorder_panes():
    """Reorder panes alphabetically by title using swap-pane.
    After each swap, updates titles on both affected panes so the
    label always matches the session running in that pane_id."""
    pane_list = get_pane_order()
    if not pane_list or len(pane_list) < 2:
        return
    sorted_panes = sorted(pane_list, key=lambda p: p[1].lower())
    for i, (desired_id, desired_title) in enumerate(sorted_panes):
        if pane_list[i][0] == desired_id:
            continue  # already in place
        # Find where desired_id currently is
        j = next((k for k, p in enumerate(pane_list) if p[0] == desired_id), None)
        if j is None:
            continue
        old_i_id, old_i_title = pane_list[i]
        # Swap programs between position i and position j
        tmux("swap-pane", "-s", desired_id, "-t", old_i_id)
        # swap-pane moves content but NOT pane options — update labels on both panes
        tmux("select-pane", "-t", old_i_id, "-T", desired_title)
        tmux("set-option", "-p", "-t", old_i_id, "@agent-label", desired_title)
        tmux("select-pane", "-t", desired_id, "-T", old_i_title)
        tmux("set-option", "-p", "-t", desired_id, "@agent-label", old_i_title)
        # Update our tracking list
        pane_list[i] = (old_i_id, desired_title)
        pane_list[j] = (desired_id, old_i_title)

def attach_cmd(session_name):
    return "while true; do TMUX= tmux attach -t " + session_name + " 2>/dev/null || sleep 2; done"

def tmux(*args):
    r = subprocess.run(["tmux"] + list(args), capture_output=True, text=True)
    if r.returncode != 0 and r.stderr.strip():
        log(f"tmux error: {{r.stderr.strip()}}")
    return r

LIGHT_BG_VOICES = {{
    "af_alloy", "am_adam", "am_onyx", "bm_fable", "af_nova", "am_eric", "bf_lily",
