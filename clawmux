#!/usr/bin/env python3
"""ClawMux CLI — voice and inter-agent messaging.

Simple shell commands that any agent runtime can call.
Connect, do one thing, print the result, exit.

Env vars:
    CLAWMUX_SESSION_ID — session ID (required for send/wait/ack/reply)
    CLAWMUX_PORT       — hub port (default 3460)
"""

import argparse
import asyncio
import json
import os
import signal
import subprocess
import sys
import time

HUB_PORT = int(os.environ.get("CLAWMUX_PORT", "3460"))
HUB_BASE = f"http://127.0.0.1:{HUB_PORT}"
SESSION_ID = os.environ.get("CLAWMUX_SESSION_ID", "")


def _find_repo_dir() -> str:
    """Find the ClawMux repo directory reliably.

    Strategy: use sys.executable (the venv python from the shebang) to derive
    the repo root.  Falls back to __file__ location, then common paths.
    """
    # 1. sys.executable points to .venv/bin/python inside the repo
    exe = os.path.realpath(sys.executable)
    venv_bin = os.path.dirname(exe)  # .../repo/.venv/bin
    if os.path.basename(os.path.dirname(venv_bin)) == ".venv":
        candidate = os.path.dirname(os.path.dirname(venv_bin))
        if os.path.isdir(os.path.join(candidate, "server")):
            return candidate

    # 2. __file__ — works when running from repo directly
    script_dir = os.path.dirname(os.path.realpath(__file__))
    if os.path.isdir(os.path.join(script_dir, "server")):
        return script_dir

    # 3. Common install paths
    for candidate in [os.path.expanduser("~/GIT/clawmux"), os.path.expanduser("~/clawmux")]:
        if os.path.isdir(os.path.join(candidate, "server")):
            return candidate

    die("Cannot find ClawMux repo directory")
    return ""  # unreachable

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def die(msg: str) -> None:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def hub_url(path: str) -> str:
    return f"{HUB_BASE}{path}"


def require_session_id() -> str:
    if not SESSION_ID:
        die("CLAWMUX_SESSION_ID not set")
    return SESSION_ID



def _rewrite_shebang(filepath: str, python_path: str) -> None:
    """Rewrite the shebang line of a file (cross-platform, no sed)."""
    import tempfile
    try:
        with open(filepath, "r") as f:
            lines = f.readlines()
        if lines:
            lines[0] = f"#!{python_path}\n"
        tmp = tempfile.NamedTemporaryFile(mode="w", delete=False, suffix=".tmp")
        tmp.writelines(lines)
        tmp.close()
        subprocess.run(["sudo", "cp", tmp.name, filepath], capture_output=True)
        subprocess.run(["sudo", "chmod", "+x", filepath], capture_output=True)
        os.unlink(tmp.name)
    except Exception as e:
        print(f"Warning: could not rewrite shebang: {e}")


def http_get(path: str) -> dict:
    """Simple HTTP GET to the hub REST API."""
    import urllib.request
    import urllib.error
    try:
        req = urllib.request.Request(hub_url(path))
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read())
    except urllib.error.URLError as e:
        die(f"cannot reach hub at {HUB_BASE}: {e.reason}")
    except Exception as e:
        die(f"http error: {e}")


def http_post(path: str, data: dict) -> dict:
    """Simple HTTP POST to the hub REST API."""
    import urllib.request
    import urllib.error
    try:
        body = json.dumps(data).encode()
        req = urllib.request.Request(
            hub_url(path),
            data=body,
            headers={"Content-Type": "application/json"},
        )
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        err = json.loads(e.read()) if e.headers.get("content-type", "").startswith("application/json") else {}
        die(err.get("error", f"HTTP {e.code}: {e.reason}"))
    except urllib.error.URLError as e:
        die(f"cannot reach hub at {HUB_BASE}: {e.reason}")
    except Exception as e:
        die(f"http error: {e}")


