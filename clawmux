def _voice_ansi_color(voice_id):
    """Map voice ID to ANSI 256-color number for terminal output."""
    palette = _VOICE_COLORS_DARK if _terminal_is_dark() else _VOICE_COLORS_LIGHT
    return palette.get(voice_id)

def _print_status_table(file=None):
    """Print the hub status table."""
    import builtins as _builtins
    _orig_print = _builtins.print
    def print(*a, **kw):
        kw.setdefault("file", file)
        _orig_print(*a, **kw)
    sessions = http_get("/api/sessions")
    debug = http_get("/api/debug")
    context = http_get("/api/context")

    hub_info = debug.get("hub", debug)
    uptime_s = hub_info.get("uptime_seconds", 0)
    h, m = int(uptime_s // 3600), int((uptime_s % 3600) // 60)
    uptime = f"{h}h {m}m" if h else f"{m}m"

    browser = hub_info.get("client_count", hub_info.get("browser_clients", 0))
    print(f"Hub: port {HUB_PORT}, uptime {uptime}, {'browser connected' if browser else 'no browser'}")
    print()

    if not sessions:
        print("No active sessions.")
        return

    # Group sessions by project_slug
    projects = http_get("/api/projects")
    proj_info = projects.get("projects", {})
    active_project = projects.get("active_project", "default")

    by_project = {}
    for s in sessions:
        slug = s.get("project_slug", "default")
        by_project.setdefault(slug, []).append(s)

    for slug in sorted(by_project.keys(), key=lambda s: (s != "default", s)):
        proj = proj_info.get(slug, {})
        proj_name = proj.get("name", slug)
        active_marker = " *" if slug == active_project else ""
        agent_count = len(by_project[slug])
        print(f"  {proj_name}{active_marker} ({agent_count} agents)")
        print(f"  {'Name':<10} {'Role':<14} {'Project':<14} {'Area':<16} {'Task':<32} {'State':<10} {'tool_name':<14} {'activity':<30} {'ctx':<5} {'model':<8} {'effort'}")
        print(f"  {'-' * 165}")
        for s in sorted(by_project[slug], key=lambda s: s.get("label", "")):
            name = s.get("label", s.get("voice", "?"))
            project = s.get("project", "") or ""
            if len(project) > 12:
                project = project[:12] + ".."
            area = s.get("project_area", "")
            if len(area) > 14:
                area = area[:12] + ".."
            role = s.get("role", "")
            if len(role) > 12:
                role = role[:10] + ".."
            task = s.get("task", "")
            if len(task) > 30:
                task = task[:28] + ".."
            # Derive state from API fields
            raw_state = s.get("state", "")
            if raw_state in ("idle", "thinking", "processing", "compacting", "starting"):
                state = raw_state
            elif s.get("status") in ("starting", "dead"):
                state = s["status"]
            elif s.get("compacting"):
                state = "compacting"
            elif s.get("in_wait"):
                state = "idle"
            elif s.get("processing"):
                state = "working"
            else:
                state = "idle"
            tool_name = s.get("tool_name", "")
            if len(tool_name) > 12:
                tool_name = tool_name[:10] + ".."
            activity = s.get("activity", "")
            if len(activity) > 28:
                activity = activity[:26] + ".."
            # Context percentage
            sid = s.get("session_id", "")
            ctx_info = context.get(sid, {})
            ctx_pct = ctx_info.get("percent")
            ctx_str = f"{ctx_pct:.0f}%" if ctx_pct is not None else ""
            # Colorize entire row using ANSI 256-color matching tmux colours
            voice = s.get("voice", "")
            ansi_color = _voice_ansi_color(voice)
            use_color = file is not None or sys.stdout.isatty()
            model = s.get("model", "") or ""
            effort = s.get("effort", "") or "default"
            row = f"  {name:<10} {role:<14} {project:<14} {area:<16} {task:<32} {state:<10} {tool_name:<14} {activity:<30} {ctx_str:<5} {model:<8} {effort}"
            if ansi_color and use_color:
                print(f"\033[38;5;{ansi_color}m{row}\033[0m")
            else:
                print(row)
        print()


def cmd_projects(args):
    """List all projects."""
    projects = http_get("/api/projects")
    proj_info = projects.get("projects", {})
    active_project = projects.get("active_project", "default")
    sessions = http_get("/api/sessions")

    # Count agents per project
    counts = {}
    for s in sessions:
        slug = s.get("project_slug", "default")
        counts[slug] = counts.get(slug, 0) + 1

    if not proj_info:
        print("No projects configured.")
        return

    print(f"{'Project':<15} {'Slug':<15} {'Agents':<8} {'Active'}")
    print("-" * 45)
    for slug, proj in sorted(proj_info.items()):
        name = proj.get("name", slug)
        agent_count = counts.get(slug, 0)
        active = "*" if slug == active_project else ""
        print(f"{name:<15} {slug:<15} {agent_count:<8} {active}")


def cmd_start(args):
    """Start the ClawMux hub."""
    # Check if already running
    try:
        http_get("/api/sessions")
        print(f"Hub is already running on port {HUB_PORT}.")
        return
    except SystemExit:
        pass  # Not running, proceed

    hub_dir = _find_repo_dir()
    venv_python = os.path.join(hub_dir, ".venv", "bin", "python")
    hub_py = os.path.join(hub_dir, "server", "hub.py")

    if not os.path.exists(venv_python):
        die(f"venv not found at {venv_python}")
    if not os.path.exists(hub_py):
        die(f"hub.py not found at {hub_py}")

    log_file = "/tmp/clawmux.log"
    print(f"Starting hub on port {HUB_PORT}...")

    with open(log_file, "a") as log:
        proc = subprocess.Popen(
            [venv_python, hub_py],
            cwd=hub_dir,
            stdout=log,
            stderr=log,
            start_new_session=True,
        )

    # Wait for hub to come up
    for i in range(30):
        time.sleep(1)
        try:
            http_get("/api/sessions")
            print(f"Hub started (PID {proc.pid}).")
            return
        except SystemExit:
            continue

    die("hub did not start within 30 seconds — check /tmp/clawmux.log")


def cmd_stop(args):
    """Stop the ClawMux hub (keeps tmux sessions alive)."""
    if not _shutdown_hub("reload"):
        if not _sigterm_hub():
            print("Hub is not running.")
            return

    # Wait for process to exit
    for _ in range(20):
        time.sleep(0.5)
        check = subprocess.run(
            ["pgrep", "-f", "python.*hub\\.py"],
            capture_output=True, text=True,
        )
        if not check.stdout.strip():
            print("Hub stopped (sessions preserved).")
            return

    print("Hub may still be shutting down.")


def cmd_spawn(args):
    """Spawn a new agent session."""
    body = {}
    if args.voice:
        body["voice"] = args.voice
    if args.label:
        body["label"] = args.label

    print("Spawning session...")
    result = http_post("/api/sessions", body)

    if "error" in result:
        die(result["error"])

    sid = result.get("session_id", "?")
    voice = result.get("voice", "?")
    print(f"Session: {sid}")
    print(f"Voice: {voice}")


def _openclaw_deliver(to_name: str, message: str) -> None:
    """Deliver a message to an OpenClaw agent by triggering a proper agent turn
    via the Gateway hooks/agent endpoint. Response is delivered back to Telegram.
    Falls back to subprocess if hooks are not configured."""
    import urllib.request, json as _json
    config_path = os.path.expanduser("~/.openclaw/openclaw.json")
    try:
        cfg = _json.load(open(config_path))
        hooks_cfg = cfg.get("hooks", {})
        token = hooks_cfg.get("token", "")
        gw_port = cfg.get("gateway", {}).get("port", 18789)
        if hooks_cfg.get("enabled") and token:
            payload = _json.dumps({
                "message": message,
                "name": "ClawMux",
                "deliver": True,
                "channel": "telegram",
            }).encode()
            req = urllib.request.Request(
                f"http://127.0.0.1:{gw_port}/hooks/agent",
                data=payload,
                headers={"Authorization": f"Bearer {token}", "Content-Type": "application/json"},
                method="POST",
            )
            urllib.request.urlopen(req, timeout=10)
            return
    except Exception:
        pass
    # Fallback: subprocess approach with session ID routing
    import subprocess
    sessions_path = os.path.expanduser("~/.openclaw/agents/main/sessions/sessions.json")
    session_id = None
    channel = None
    if os.path.exists(sessions_path):
        try:
            sessions = _json.load(open(sessions_path))
            tg_entry = next((v for k, v in sessions.items() if ":telegram:direct:" in k), None)
            entry = tg_entry or next(iter(sessions.values()), None)
            if entry:
                session_id = entry.get("sessionId")
                channel = entry.get("lastChannel")
        except Exception:
            pass
    cmd = ["openclaw", "agent", "--agent", "main", "--message", message]
    if session_id:
        cmd += ["--session-id", session_id]
    if channel:
        cmd += ["--channel", channel]
    subprocess.run(cmd, capture_output=True)


def cmd_send(args):
    """Send a message to another agent or to the user."""
    sender_override = getattr(args, "sender_override", None)
    message = args.message or ""

    # Bare ack: --re with no content
    if not message and not getattr(args, "re", None):
        die("message is required (or use --re for bare acknowledgment)")

    # External sender path: --from bypasses session validation, uses dedicated endpoint + token
    if sender_override:
        token_path = os.path.join(clawmux_home, "data", "external_token")
        try:
            token = open(token_path).read().strip()
        except OSError:
            die(f"external token not found at {token_path} — is the hub running?")
        payload = {
            "sender": sender_override,
            "to": args.to,
            "message": message,
        }
        if getattr(args, "re", None):
            payload["parent_id"] = args.re
        result = http_post("/api/messages/external", payload,
                           headers={"X-ClawMux-Token": token})
        print(result.get("id", ""))
        return

    session_id = require_session_id()
    payload = {
        "sender": session_id,
        "to": args.to,
        "message": message,
    }
    if getattr(args, "re", None):
        payload["parent_id"] = args.re

    if args.to == "user":
        if not message and not getattr(args, "re", None):
            die("message is required for --to user (unless using --re for ack)")
        if not message and getattr(args, "re", None):
            # Bare ack to user message — no TTS, just notify browser of thumbs up
            result = http_post("/api/messages/speak", {**payload, "ack_only": True})
            msg_id = result.get("id", "")
            print(msg_id)
            return
        # TTS message to user — fire and forget
        result = http_post("/api/messages/speak", payload)
        msg_id = result.get("id", "")
        print(msg_id)
        return

    # External delivery via OpenClaw: log to hub + deliver
    if getattr(args, "via", None) == "openclaw":
        if not message:
            die("message is required for external delivery")
        _home = os.environ.get("CLAWMUX_HOME", os.path.expanduser("~/.clawmux"))
        token_path = os.path.join(_home, "data", "external_token")
        try:
            token = open(token_path).read().strip()
        except OSError:
            die(f"external token not found at {token_path} — is the hub running?")
        # Derive sender name from session_id (e.g. "af_sky" -> "sky")
        sender_name = session_id.split("_", 1)[-1] if "_" in session_id else session_id
        log_payload = {"sender": sender_name, "to": args.to, "message": message}
        if getattr(args, "re", None):
            log_payload["parent_id"] = args.re
        result = http_post("/api/messages/external/outbound", log_payload,
                           headers={"X-ClawMux-Token": token})
        _openclaw_deliver(args.to, message)
        print(result.get("id", ""))
        return

    result = http_post("/api/messages/send", payload)

    msg_id = result["id"]
    print(msg_id)


def cmd_kill(args):
    """Kill a single agent session."""
    agent = args.agent.lower()

    if args.force:
        # Forced: just kill the tmux session directly
        r = subprocess.run(["tmux", "kill-session", "-t", agent],
                           capture_output=True, text=True)
        if r.returncode != 0:
            die(f"tmux session '{agent}' not found")
        print(f"Killed {agent} (forced)")
        return

    # Graceful: resolve session, call DELETE API, then kill tmux
    session_id = _resolve_agent_session_id(agent)
    http_delete(f"/api/sessions/{session_id}")
    # Kill tmux session (may already be gone from API cleanup)
    subprocess.run(["tmux", "kill-session", "-t", agent],
                   capture_output=True, text=True)
    print(f"Killed {agent} (graceful)")


def cmd_kill_all(args):
    """Stop the hub AND kill all voice tmux sessions."""
    if _shutdown_hub("full"):
        print("Stopping hub...")
    else:
        _sigterm_hub()
        print("Hub is not running or using old version, cleaning up sessions...")

    # Wait for hub to exit
    for _ in range(20):
        time.sleep(0.5)
        check = subprocess.run(["pgrep", "-f", "python.*hub\\.py"], capture_output=True, text=True)
        if not check.stdout.strip():
            break

    # Kill any remaining voice-* tmux sessions
    result = subprocess.run(
        ["tmux", "list-sessions", "-F", "#{session_name}"],
        capture_output=True, text=True,
    )
    killed = 0
    if result.returncode == 0:
        for name in result.stdout.strip().splitlines():
            if name.startswith("voice-"):
                subprocess.run(["tmux", "kill-session", "-t", name], capture_output=True)
                killed += 1

    print(f"Hub stopped. Killed {killed} session(s).")


def cmd_version(args):
    """Show ClawMux version and git commit."""
    repo_dir = _find_repo_dir()
