def cmd_regenerate(args):
    """Regenerate CLAUDE.md templates for agents."""
    if args.agent:
        result = http_post(f"/api/agents/{args.agent}/regenerate", {})
        print(f"Regenerated CLAUDE.md for {result.get('regenerated', args.agent)}")
    else:
        result = http_post("/api/agents/regenerate", {})
        print(f"Regenerated {result.get('regenerated', 0)} CLAUDE.md files")


def cmd_project(args):
    """Set project status in the sidebar."""
    session_id = require_session_id()
    payload = {
        "project": args.project,
        "area": args.area or "",
    }
    if args.role:
        payload["role"] = args.role
    if args.task:
        payload["task"] = args.task
    http_post(f"/api/project-status/{session_id}", payload)
    area = f" · {args.area}" if args.area else ""
    print(f"Project: {args.project}{area}")


def cmd_task(args):
    """Set task description in the sidebar."""
    session_id = require_session_id()
    http_post(f"/api/project-status/{session_id}", {"task": args.description})
    print(f"Task: {args.description}")


def cmd_role(args):
    """Set agent role in the sidebar."""
    session_id = require_session_id()
    # Validate against available role templates
    try:
        available = http_get("/api/roles").get("roles", [])
    except Exception:
        available = []
    role_lower = args.role.lower()
    if available and role_lower not in available:
        print(f"Error: '{args.role}' is not a valid role.")
        print(f"Available roles: {', '.join(available)}")
        sys.exit(1)
    http_post(f"/api/project-status/{session_id}", {"role": role_lower})
    print(f"Role: {role_lower}")


