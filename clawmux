def main():
    parser = argparse.ArgumentParser(
        prog="clawmux",
        description="ClawMux CLI — voice and inter-agent messaging",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""commands:
  Hub Management:
    start       Start the ClawMux hub
    stop        Stop the ClawMux hub
    reload      Restart the hub (agents auto-reconnect)
    status      Show hub state and session info
    projects    List all projects

  Messaging:
    send        Send a message to an agent or user (TTS)
    wait        Block until a message arrives (idle mode)
    ack         Acknowledge receipt of a message
    reply       Reply to a specific message

  Monitoring:
    monitor     Open tiled tmux view of agent sessions (per project)

  Session:
    spawn       Launch a new agent session
    kill        Kill a single agent session
    project     Set project status in sidebar

  Headless:
    run         Run a one-shot Claude prompt (no session/voice)

  System:
    version     Show version and commit
    update      Update to latest version
    uninstall   Remove ClawMux

examples:
    clawmux status
    clawmux status sky
    clawmux projects
    clawmux send --to user "Hello, what should I work on?"
    clawmux send --to alloy "Check the auth module"
    clawmux wait
    clawmux start
    clawmux reload
    clawmux monitor
    clawmux monitor --agents sky adam echo
    clawmux run 'Summarize: some text here'""",
    )
    sub = parser.add_subparsers(dest="command", required=False)

    # version
    p = sub.add_parser("version", help="Show ClawMux version and commit")
    p.set_defaults(func=cmd_version)

    # wait (NEW — push-based idle mode)
    p = sub.add_parser("wait", help="Block until a message arrives",
                       description="Enter idle mode. Blocks until an inbox message arrives, then prints it to stdout.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux wait                     # Block until message arrives
    text=$(clawmux wait)             # Capture message text""")
    p.set_defaults(func=cmd_wait)

    # send
    p = sub.add_parser("send", help="Send a message to an agent or user",
                       description="Send a message to another agent or to the user. Use --to user for TTS output.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux send --to alloy "FYI, I pushed a fix."
    clawmux send --to user "Here's what I found."
    clawmux send --to alloy --re msg-abc123 "Got it, thanks."
    clawmux send --to alloy --wait-ack "Can you check the auth module?" """)
    p.add_argument("--to", required=True, help="Recipient: agent name (e.g. sky, echo) or 'user' for TTS")
    p.add_argument("message", nargs="?", default="", help="Message text (optional with --re for bare acknowledgment)")
    p.add_argument("--re", help="Parent message ID for threaded reply (e.g. msg-abc123)")
    p.add_argument("--wait-ack", action="store_true", help="[DEPRECATED] Block until recipient acknowledges")
    p.add_argument("--wait-response", action="store_true", help="[DEPRECATED] Block until recipient replies")
    p.set_defaults(func=cmd_send)

    # ack (DEPRECATED)
    p = sub.add_parser("ack", help="[DEPRECATED] Acknowledge receipt of a message",
                       description="DEPRECATED: Use 'clawmux send --to <agent> --re <msg_id>' instead.")
    p.add_argument("msg_id", help="Message ID to acknowledge (e.g. msg-a1b2c3)")
    p.set_defaults(func=cmd_ack)

    # reply (DEPRECATED)
    p = sub.add_parser("reply", help="[DEPRECATED] Reply to a message",
                       description="DEPRECATED: Use 'clawmux send --to <agent> --re <msg_id> \"reply text\"' instead.")
    p.add_argument("msg_id", help="Message ID to reply to")
    p.add_argument("message", help="Reply text")
    p.set_defaults(func=cmd_reply)

    # status
    p = sub.add_parser("status", help="Show hub state and session info",
                       description="Show hub overview or detailed info for a specific agent.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux status              # Hub overview with all sessions
    clawmux status sky          # Detailed info for Sky""")
    p.add_argument("agent", nargs="?", help="Agent name for detailed status (e.g. sky, alloy)")
    p.set_defaults(func=cmd_status)

    # projects
    p = sub.add_parser("projects", help="List all projects",
                       description="Show all configured projects with agent counts.")
    p.set_defaults(func=cmd_projects)

    # start
    p = sub.add_parser("start", help="Start the ClawMux hub",
                       description="Launch the hub process. Exits if hub is already running.")
    p.set_defaults(func=cmd_start)

    # stop
    p = sub.add_parser("stop", help="Stop the ClawMux hub",
                       description="Gracefully stop the hub. Agent tmux sessions are preserved.")
    p.set_defaults(func=cmd_stop)

    # reload
    p = sub.add_parser("reload", help="Restart the hub (agents auto-reconnect)",
                       description="Stop and restart the hub. Active agent sessions reconnect automatically.")
    p.set_defaults(func=cmd_reload)

    # spawn
    p = sub.add_parser("spawn", help="Spawn a new agent session",
                       description="Launch a new agent session via the hub.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux spawn --voice am_echo
    clawmux spawn --voice af_sky
    clawmux spawn --voice am_echo --label "Echo Agent" """)
    p.add_argument("--voice", help="TTS voice (e.g. af_sky, am_echo, am_onyx)")
    p.add_argument("--label", help="Custom label for the session")
    p.set_defaults(func=cmd_spawn)

    # monitor
    p = sub.add_parser("monitor", help="Open tiled tmux view of agent sessions",
                       description="Create a tmux session with tiled panes showing agent sessions. Optionally specify a project slug to monitor only that project's agents.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux monitor                          # Monitor default project agents
    clawmux monitor hnapp                    # Monitor hnapp project agents
    clawmux monitor --agents sky adam echo   # Monitor specific agents
    clawmux monitor --detach                 # Create without attaching
    clawmux monitor --restart                # Kill existing and recreate
