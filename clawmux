def cmd_wait(args):
    """Block until an inbox message arrives, then print it."""
    import atexit
    import signal

    session_id = require_session_id()

    # Write .waiting sentinel immediately so stop hook can detect intent without polling.
    # Use CLAWMUX_WORK_DIR (voice_id-based) if set; fall back to session_id-based path.
    clawmux_home = os.environ.get("CLAWMUX_HOME", os.path.expanduser("~/.clawmux"))
    work_dir = os.environ.get("CLAWMUX_WORK_DIR") or os.path.join(clawmux_home, "sessions", session_id)
    sentinel_path = os.path.join(work_dir, ".waiting")
    # Kill any previous clawmux wait instance to prevent accumulation
    try:
        with open(sentinel_path, "r") as _f:
            old_pid = int(_f.read().strip())
        if old_pid != os.getpid():
            try:
                os.kill(old_pid, signal.SIGTERM)
            except (ProcessLookupError, PermissionError):
                pass
    except (OSError, ValueError):
        pass
    try:
        with open(sentinel_path, "w") as _f:
            _f.write(str(os.getpid()))
    except OSError:
        pass  # non-fatal; stop hook falls back to exit 2

    def _remove_sentinel():
        try:
            os.unlink(sentinel_path)
        except OSError:
            pass

    atexit.register(_remove_sentinel)
    signal.signal(signal.SIGTERM, lambda _s, _f: sys.exit(0))

    async def _wait():
        from websockets.asyncio.client import connect as ws_connect
        url = f"ws://127.0.0.1:{HUB_PORT}/ws/wait/{session_id}"
        max_retries = 30  # ~30 seconds of retrying
        for attempt in range(max_retries):
            try:
                async with ws_connect(url) as ws:
                    while True:
                        raw = await ws.recv()
                        data = json.loads(raw)
                        if data.get("type") == "ping":
                            continue
                        if data.get("type") == "messages":
                            messages = data.get("messages", [])
                            for msg in messages:
                                msg_type = msg.get("type", "system")
                                sender = msg.get("from", "unknown")
                                content = msg.get("content", "")
                                msg_id = msg.get("msg_id") or msg.get("id", "")
                                if msg_type == "ack":
                                    parent = msg.get("parent_id", "?")
                                    print(f"[ACK id:{msg_id} from:{sender} on:{parent}]")
                                elif msg_type == "agent":
                                    print(f"[MSG id:{msg_id} from:{sender}] {content}")
                                elif msg_type == "voice":
                                    print(f"[VOICE id:{msg_id} from:{sender}] {content}")
                                else:
                                    print(f"[SYSTEM] {content}")
                            return
            except ConnectionRefusedError:
                if attempt == max_retries - 1:
                    die(f"cannot connect to hub at port {HUB_PORT} — is the hub running?")
                await asyncio.sleep(1)
            except Exception:
                if attempt == max_retries - 1:
                    die(f"cannot connect to hub after {max_retries} retries")
                await asyncio.sleep(1)

    asyncio.run(_wait())


def cmd_status(args):
    """Show hub state and session info."""
    if args.agent:
        # Per-agent detail
        sessions = http_get("/api/sessions")
        found = None
        for s in sessions:
            name = s.get("voice", "").replace("af_", "").replace("am_", "").replace("bm_", "")
            if name == args.agent or s.get("voice") == args.agent or s.get("session_id") == args.agent:
                found = s
                break
        if not found:
            die(f"no session found for '{args.agent}'")

        print(f"Agent: {found.get('label', found.get('voice', '?'))}")
        print(f"  Voice: {found.get('voice', '?')}")
        # Derive high-level state
        if found.get("status") in ("starting", "dead"):
            detail_state = found["status"]
        elif found.get("compacting"):
            detail_state = "working"
        elif found.get("in_wait"):
            detail_state = "waiting"
        elif found.get("status_text") or found.get("processing"):
            detail_state = "working"
        else:
            detail_state = "idle"
        print(f"  State: {detail_state}")
        # Show tool activity as sub-detail
        activity = found.get("status_text", "")
        if found.get("compacting"):
            activity = "Compacting context"
        if activity:
            print(f"  Activity: {activity}")
        print(f"  Session ID: {found.get('session_id', '?')}")
        if found.get("project"):
            area = f" · {found['project_area']}" if found.get("project_area") else ""
            print(f"  Project: {found['project']}{area}")
        if found.get("work_dir"):
            print(f"  Work dir: {found['work_dir']}")
        if found.get("model"):
            print(f"  Model: {found['model']}")
        return

    if getattr(args, "watch", False):
        import time as _time, io as _io
        print("\033[2J\033[H\033[?25l", end="", flush=True)  # clear screen, hide cursor
        try:
            while True:
                try:
                    buf = _io.StringIO()
                    _print_status_table(file=buf)
                    output = buf.getvalue()
                except Exception:
                    output = "Hub unreachable — waiting for reconnect...\n"
                # Move cursor home and overwrite (no clear = no flash)
                print("\033[H", end="", flush=True)
                print(output, end="", flush=True)
                # Clear any leftover lines from previous render
                print("\033[J", end="", flush=True)
                _time.sleep(0.5)
        except KeyboardInterrupt:
            pass
        finally:
            print("\033[?25h", end="", flush=True)  # restore cursor
        return
    else:
        _print_status_table()


def _query_terminal_bg():
    """Query the terminal for its background color via OSC 11.

    Works through SSH — queries the actual client terminal (iTerm2, Ghostty, etc.).
    Returns True for dark, False for light, None if query fails.
    """
    import select, termios, tty
    if not os.isatty(sys.stdin.fileno()):
        return None
    try:
        fd = sys.stdin.fileno()
        old_settings = termios.tcgetattr(fd)
        try:
            tty.setraw(fd)
            # Send OSC 11 query: "what is your background color?"
            sys.stdout.write("\033]11;?\033\\")
            sys.stdout.flush()
            # Wait for response with short timeout
            if not select.select([fd], [], [], 0.3)[0]:
                return None
            response = b""
            while select.select([fd], [], [], 0.05)[0]:
                response += os.read(fd, 64)
            return _parse_osc11_response(response.decode("latin-1"))
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
    except Exception:
        return None

def _parse_osc11_response(response):
    """Parse OSC 11 response to determine if background is dark.

    Response format: ESC ] 11 ; rgb:RRRR/GGGG/BBBB ESC \\
    Returns True for dark, False for light.
    """
    import re
    m = re.search(r"rgb:([0-9a-fA-F]+)/([0-9a-fA-F]+)/([0-9a-fA-F]+)", response)
    if not m:
        return None
    # Normalize to 0-255 range (values can be 2 or 4 hex digits)
    vals = []
    for hex_val in m.groups():
        v = int(hex_val, 16)
        if len(hex_val) == 4:
            v = v >> 8  # scale 16-bit to 8-bit
        vals.append(v)
    r, g, b = vals
    # Perceived luminance (ITU-R BT.709)
    luminance = 0.2126 * r + 0.7152 * g + 0.0722 * b
    return luminance < 128  # dark if luminance is low

def _is_dark_terminal():
    """Detect if the terminal has a dark background."""
    # 1. Explicit override: CLAWMUX_THEME=dark|light
    theme = os.environ.get("CLAWMUX_THEME", "").lower()
    if theme in ("dark", "d"):
        return True
    if theme in ("light", "l"):
        return False
    # 2. Check COLORFGBG (set by some terminals like xterm, rxvt)
    colorfgbg = os.environ.get("COLORFGBG", "")
    if colorfgbg:
        try:
            bg = int(colorfgbg.rsplit(";", 1)[-1])
            return bg < 8
        except (ValueError, IndexError):
            pass
    # 3. Query terminal directly via OSC 11 (works through SSH)
    result = _query_terminal_bg()
    if result is not None:
        return result
    # 4. Check system dark mode (GNOME/freedesktop) — only useful locally
    if not os.environ.get("SSH_CLIENT"):
        try:
            r = subprocess.run(
                ["gsettings", "get", "org.gnome.desktop.interface", "color-scheme"],
                capture_output=True, text=True, timeout=1,
            )
            if r.returncode == 0:
                val = r.stdout.strip().strip("'\"")
                if "dark" in val:
                    return True
                if "light" in val or "default" in val:
                    return False
        except Exception:
            pass
    # 5. Default to dark
    return True

_dark_terminal_cache = None
def _terminal_is_dark():
    global _dark_terminal_cache
    if _dark_terminal_cache is None:
        _dark_terminal_cache = _is_dark_terminal()
    return _dark_terminal_cache

