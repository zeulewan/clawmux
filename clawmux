def _parse_date_or_ts(val: str) -> str:
    """Convert a date string (YYYY-MM-DD) or unix timestamp to a timestamp string."""
    from datetime import datetime
    try:
        return str(float(val))
    except ValueError:
        pass
    try:
        dt = datetime.strptime(val, "%Y-%m-%d")
        return str(dt.timestamp())
    except ValueError:
        die(f"invalid date/timestamp: {val} (use YYYY-MM-DD or unix timestamp)")


def _fmt_msg_line(msg, vname, max_text=200):
    """Format a single message for CLI output."""
    from datetime import datetime
    role = msg.get("role", "?")
    ts = msg.get("ts", 0)
    dt = datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M") if ts else "?"
    text = msg.get("text", "")
    if len(text) > max_text:
        text = text[:max_text] + "..."
    text = text.replace("\n", " ")
    return f"  [{dt}] {vname} ({role}): {text}"


def cmd_search(args):
    """Search across agent conversation histories."""
    import urllib.parse
    params = {"q": args.query, "limit": str(args.limit)}
    if args.agent:
        params["agent"] = args.agent
    if args.role:
        params["role"] = args.role
    if args.after:
        params["after"] = _parse_date_or_ts(args.after)
    if args.before:
        params["before"] = _parse_date_or_ts(args.before)
    if args.context:
        params["context"] = str(args.context)
    qs = urllib.parse.urlencode(params)
    data = http_get(f"/api/search?{qs}")
    results = data.get("results", [])
    if not results:
        print("No results found.")
        return

    print(f"Found {data.get('count', len(results))} result(s) for \"{args.query}\":\n")
    has_context = args.context and args.context > 0
    for i, r in enumerate(results):
        vname = r.get("voice_name", r["voice_id"])
        if has_context and "context" in r:
            if i > 0:
                print()
            print(f"  --- {vname} ---")
            for cm in r["context"]:
                marker = ">>>" if cm.get("is_match") else "   "
                line = _fmt_msg_line(cm, vname)
                print(f"{marker}{line}")
        else:
            print(_fmt_msg_line(r["message"], vname))
    if data.get("count", 0) > len(results):
        print(f"\n  (showing {len(results)} of {data['count']} — use --limit to see more)")


