def cmd_wait(args):
    """Block until an inbox message arrives, then print it."""
    session_id = require_session_id()

    async def _wait():
        from websockets.asyncio.client import connect as ws_connect
        url = f"ws://127.0.0.1:{HUB_PORT}/ws/wait/{session_id}"
        try:
            async with ws_connect(url) as ws:
                while True:
                    raw = await ws.recv()
                    data = json.loads(raw)
                    if data.get("type") == "ping":
                        continue
                    if data.get("type") == "messages":
                        messages = data.get("messages", [])
                        for msg in messages:
                            msg_type = msg.get("type", "system")
                            sender = msg.get("from", "unknown")
                            content = msg.get("content", "")
                            msg_id = msg.get("msg_id") or msg.get("id", "")
                            if msg_type == "ack":
                                parent = msg.get("parent_id", "?")
                                print(f"[ACK id:{msg_id} from:{sender} on:{parent}]")
                            elif msg_type == "agent":
                                print(f"[MSG id:{msg_id} from:{sender}] {content}")
                            elif msg_type == "voice":
                                print(f"[VOICE id:{msg_id} from:{sender}] {content}")
                            else:
                                print(f"[SYSTEM] {content}")
                        return
        except ConnectionRefusedError:
            die(f"cannot connect to hub at port {HUB_PORT} — is the hub running?")
        except Exception as e:
            die(f"websocket error: {e}")

    asyncio.run(_wait())


def cmd_status(args):
    """Show hub state and session info."""
    if args.agent:
        # Per-agent detail
        sessions = http_get("/api/sessions")
        found = None
        for s in sessions:
            name = s.get("voice", "").replace("af_", "").replace("am_", "").replace("bm_", "")
            if name == args.agent or s.get("voice") == args.agent or s.get("session_id") == args.agent:
                found = s
                break
        if not found:
            die(f"no session found for '{args.agent}'")

        print(f"Agent: {found.get('label', found.get('voice', '?'))}")
        print(f"  Voice: {found.get('voice', '?')}")
        # Derive high-level state
        if found.get("status") in ("starting", "dead"):
            detail_state = found["status"]
        elif found.get("compacting"):
            detail_state = "working"
        elif found.get("in_wait"):
            detail_state = "waiting"
        elif found.get("status_text") or found.get("processing"):
            detail_state = "working"
        else:
            detail_state = "idle"
        print(f"  State: {detail_state}")
        # Show tool activity as sub-detail
        activity = found.get("status_text", "")
        if found.get("compacting"):
            activity = "Compacting context"
        if activity:
            print(f"  Activity: {activity}")
        print(f"  Session ID: {found.get('session_id', '?')}")
        if found.get("project"):
            area = f" · {found['project_area']}" if found.get("project_area") else ""
            print(f"  Project: {found['project']}{area}")
        if found.get("work_dir"):
            print(f"  Work dir: {found['work_dir']}")
        if found.get("model"):
            print(f"  Model: {found['model']}")
        return

    # Hub overview
    sessions = http_get("/api/sessions")
    debug = http_get("/api/debug")

    hub_info = debug.get("hub", debug)
    uptime_s = hub_info.get("uptime_seconds", 0)
    h, m = int(uptime_s // 3600), int((uptime_s % 3600) // 60)
    uptime = f"{h}h {m}m" if h else f"{m}m"

    browser = hub_info.get("client_count", hub_info.get("browser_clients", 0))
    print(f"Hub: port {HUB_PORT}, uptime {uptime}, {'browser connected' if browser else 'no browser'}")
    print()

    if not sessions:
        print("No active sessions.")
        return

    # Group sessions by project_slug
    projects = http_get("/api/projects")
    proj_info = projects.get("projects", {})
    active_project = projects.get("active_project", "default")

    by_project = {}
    for s in sessions:
        slug = s.get("project_slug", "default")
        by_project.setdefault(slug, []).append(s)

    for slug in sorted(by_project.keys(), key=lambda s: (s != "default", s)):
        proj = proj_info.get(slug, {})
        proj_name = proj.get("name", slug)
        active_marker = " *" if slug == active_project else ""
        agent_count = len(by_project[slug])
        print(f"  {proj_name}{active_marker} ({agent_count} agents)")
        print(f"  {'Name':<10} {'State':<8} {'Activity':<22} {'Area':<22} {'Work Dir'}")
        print(f"  {'-' * 90}")
        for s in sorted(by_project[slug], key=lambda s: s.get("label", "")):
            name = s.get("label", s.get("voice", "?"))
            # Derive high-level state (matches sidebar)
            if s.get("status") in ("starting", "dead"):
                state = s["status"]
            elif s.get("compacting"):
                state = "working"
            elif s.get("in_wait"):
                state = "waiting"
            elif s.get("status_text") or s.get("processing"):
                state = "working"
            else:
                state = "idle"
            # Tool activity as separate column
            activity = s.get("status_text", "")
            if s.get("compacting"):
                activity = "Compacting..."
            if len(activity) > 20:
                activity = activity[:18] + ".."
            area = s.get("project_area", "")
            work_dir = s.get("work_dir", "")
            work_dir = work_dir.replace("/home/zeul/", "~/").replace("/tmp/clawmux-sessions/", "~/sessions/")
            print(f"  {name:<10} {state:<8} {activity:<22} {area:<22} {work_dir}")
        print()


def cmd_projects(args):
    """List all projects."""
    projects = http_get("/api/projects")
    proj_info = projects.get("projects", {})
    active_project = projects.get("active_project", "default")
    sessions = http_get("/api/sessions")

    # Count agents per project
    counts = {}
    for s in sessions:
        slug = s.get("project_slug", "default")
        counts[slug] = counts.get(slug, 0) + 1

    if not proj_info:
        print("No projects configured.")
        return

    print(f"{'Project':<15} {'Slug':<15} {'Agents':<8} {'Active'}")
    print("-" * 45)
    for slug, proj in sorted(proj_info.items()):
        name = proj.get("name", slug)
        agent_count = counts.get(slug, 0)
        active = "*" if slug == active_project else ""
        print(f"{name:<15} {slug:<15} {agent_count:<8} {active}")


def cmd_start(args):
    """Start the ClawMux hub."""
    # Check if already running
    try:
        http_get("/api/sessions")
        print(f"Hub is already running on port {HUB_PORT}.")
        return
    except SystemExit:
        pass  # Not running, proceed

    hub_dir = _find_repo_dir()
    venv_python = os.path.join(hub_dir, ".venv", "bin", "python")
    hub_py = os.path.join(hub_dir, "server", "hub.py")

    if not os.path.exists(venv_python):
        die(f"venv not found at {venv_python}")
    if not os.path.exists(hub_py):
        die(f"hub.py not found at {hub_py}")

    log_file = "/tmp/clawmux.log"
    print(f"Starting hub on port {HUB_PORT}...")

    with open(log_file, "a") as log:
        proc = subprocess.Popen(
            [venv_python, hub_py],
            cwd=hub_dir,
            stdout=log,
            stderr=log,
            start_new_session=True,
        )

    # Wait for hub to come up
    for i in range(30):
        time.sleep(1)
        try:
            http_get("/api/sessions")
            print(f"Hub started (PID {proc.pid}).")
            return
        except SystemExit:
            continue

    die("hub did not start within 30 seconds — check /tmp/clawmux.log")


def cmd_stop(args):
    """Stop the ClawMux hub (keeps tmux sessions alive)."""
    if not _shutdown_hub("reload"):
        if not _sigterm_hub():
            print("Hub is not running.")
            return

    # Wait for process to exit
    for _ in range(20):
        time.sleep(0.5)
        check = subprocess.run(
            ["pgrep", "-f", "python.*hub\\.py"],
            capture_output=True, text=True,
        )
        if not check.stdout.strip():
            print("Hub stopped (sessions preserved).")
            return

    print("Hub may still be shutting down.")


def cmd_spawn(args):
    """Spawn a new agent session."""
    body = {}
    if args.voice:
        body["voice"] = args.voice
    if args.label:
        body["label"] = args.label

    print("Spawning session...")
    result = http_post("/api/sessions", body)

    if "error" in result:
        die(result["error"])

    sid = result.get("session_id", "?")
    voice = result.get("voice", "?")
    print(f"Session: {sid}")
    print(f"Voice: {voice}")


def cmd_send(args):
    """Send a message to another agent or to the user."""
    session_id = require_session_id()
    message = args.message or ""

    # Bare ack: --re with no content
    if not message and not getattr(args, "re", None):
        die("message is required (or use --re for bare acknowledgment)")

    payload = {
        "sender": session_id,
        "to": args.to,
        "message": message,
        "expect_response": getattr(args, "wait_response", False),
    }
    if getattr(args, "re", None):
        payload["parent_id"] = args.re

    if args.to == "user":
        if not message and not getattr(args, "re", None):
            die("message is required for --to user (unless using --re for ack)")
        if not message and getattr(args, "re", None):
            # Bare ack to user message — no TTS, just notify browser of thumbs up
            result = http_post("/api/messages/speak", {**payload, "ack_only": True})
            msg_id = result.get("id", "")
            print(msg_id)
            return
        # TTS message to user — fire and forget
        result = http_post("/api/messages/speak", payload)
        msg_id = result.get("id", "")
        print(msg_id)
        return

    result = http_post("/api/messages/send", payload)

    msg_id = result["id"]
    print(msg_id)

    if args.wait_ack:
        print("DEPRECATED: --wait-ack is deprecated. Use 'clawmux wait' for push-based delivery.", file=sys.stderr)
        # Poll for acknowledgment
        deadline = time.time() + 30
        while time.time() < deadline:
            time.sleep(2)
            msg = http_get(f"/api/messages/{msg_id}")
            if msg.get("state") in ("acknowledged", "responded"):
                print("acknowledged", file=sys.stderr)
                return
            if msg.get("state") == "failed":
                die("message delivery failed")
        die("timeout waiting for acknowledgment")

    if getattr(args, "wait_response", False):
        print("DEPRECATED: --wait-response is deprecated. Use 'clawmux wait' for push-based delivery.", file=sys.stderr)
        # Poll for response
        deadline = time.time() + 120
        while time.time() < deadline:
            time.sleep(2)
            msg = http_get(f"/api/messages/{msg_id}")
            if msg.get("state") == "responded":
                print(msg.get("response_text", ""))
                return
            if msg.get("state") == "failed":
                die("message delivery failed")
        die("timeout waiting for response")


def cmd_ack(args):
    """Acknowledge receipt of a message."""
    print("DEPRECATED: Use 'clawmux send --to <agent> --re <msg_id>' for threaded replies.", file=sys.stderr)
    import urllib.request
    import urllib.error
    try:
        req = urllib.request.Request(
            hub_url(f"/api/messages/{args.msg_id}/ack"),
            data=b"{}",
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=10) as resp:
            json.loads(resp.read())
        print(f"acknowledged {args.msg_id}")
    except urllib.error.HTTPError as e:
        die(f"ack failed: {e.reason}")
    except Exception as e:
        die(f"ack error: {e}")


def cmd_reply(args):
    """Reply to a specific message."""
    print("DEPRECATED: Use 'clawmux send --to <agent> --re <msg_id> \"reply text\"' instead.", file=sys.stderr)
    result = http_post(f"/api/messages/{args.msg_id}/reply", {
        "message": args.message,
    })
    print(f"replied to {args.msg_id}")


def cmd_kill(args):
    """Kill a single agent session."""
    agent = args.agent.lower()

    if args.force:
        # Forced: just kill the tmux session directly
        r = subprocess.run(["tmux", "kill-session", "-t", agent],
                           capture_output=True, text=True)
        if r.returncode != 0:
            die(f"tmux session '{agent}' not found")
        print(f"Killed {agent} (forced)")
        return

    # Graceful: resolve session, call DELETE API, then kill tmux
    session_id = _resolve_agent_session_id(agent)
    http_delete(f"/api/sessions/{session_id}")
    # Kill tmux session (may already be gone from API cleanup)
    subprocess.run(["tmux", "kill-session", "-t", agent],
                   capture_output=True, text=True)
    print(f"Killed {agent} (graceful)")


def cmd_kill_all(args):
    """Stop the hub AND kill all voice tmux sessions."""
    if _shutdown_hub("full"):
        print("Stopping hub...")
    else:
        _sigterm_hub()
        print("Hub is not running or using old version, cleaning up sessions...")

    # Wait for hub to exit
    for _ in range(20):
        time.sleep(0.5)
        check = subprocess.run(["pgrep", "-f", "python.*hub\\.py"], capture_output=True, text=True)
        if not check.stdout.strip():
            break

    # Kill any remaining voice-* tmux sessions
    result = subprocess.run(
        ["tmux", "list-sessions", "-F", "#{session_name}"],
        capture_output=True, text=True,
    )
    killed = 0
    if result.returncode == 0:
        for name in result.stdout.strip().splitlines():
            if name.startswith("voice-"):
                subprocess.run(["tmux", "kill-session", "-t", name], capture_output=True)
                killed += 1

    print(f"Hub stopped. Killed {killed} session(s).")


def cmd_version(args):
    """Show ClawMux version and git commit."""
    repo_dir = _find_repo_dir()
    # Get version from git describe (tag + commits since + short hash)
    r = subprocess.run(["git", "describe", "--tags", "--always"],
                       cwd=repo_dir, capture_output=True, text=True)
    version = r.stdout.strip() if r.returncode == 0 else "unknown"
    # Get full commit hash
    r2 = subprocess.run(["git", "rev-parse", "HEAD"],
                        cwd=repo_dir, capture_output=True, text=True)
    commit = r2.stdout.strip()[:10] if r2.returncode == 0 else "unknown"
    print(f"ClawMux {version} (commit {commit})")


def _check_system_deps():
    """Check for and install missing system dependencies (tmux, python3-venv)."""
    import platform
    import shutil
    is_mac = platform.system() == "Darwin"
    installed = []

    # Extend PATH for lookup — venv python may have a minimal PATH
    extra_paths = "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
    lookup_path = os.environ.get("PATH", "") + os.pathsep + extra_paths

    # Check tmux
    if shutil.which("tmux", path=lookup_path) is None:
        print("tmux not found, installing...")
        brew = shutil.which("brew", path=lookup_path)
        if is_mac and brew:
            r = subprocess.run([brew, "install", "tmux"], capture_output=True, text=True)
        elif is_mac:
            print("Warning: brew not found — install tmux manually (brew install tmux)")
            r = None
        else:
            r = subprocess.run(["sudo", "apt", "install", "-y", "tmux"], capture_output=True, text=True)
        if r is not None and r.returncode == 0:
            installed.append("tmux")
        elif r is not None:
            print(f"Warning: failed to install tmux: {r.stderr.strip()}")

    # Check python3-venv (Linux only)
    if not is_mac:
        # Test if venv module is available
        r = subprocess.run(["python3", "-c", "import venv"], capture_output=True, text=True)
        if r.returncode != 0:
            print("python3-venv not found, installing...")
            r = subprocess.run(["sudo", "apt", "install", "-y", "python3-venv"], capture_output=True, text=True)
            if r.returncode == 0:
                installed.append("python3-venv")
            else:
                print(f"Warning: failed to install python3-venv: {r.stderr.strip()}")

    if installed:
        print(f"Installed: {', '.join(installed)}")


def cmd_update(args):
    """Pull latest code, reinstall deps, reinstall CLI, reload hub."""
    repo_dir = _find_repo_dir()

    print(f"Updating ClawMux in {repo_dir}...")

    # Git pull
    r = subprocess.run(["git", "pull"], cwd=repo_dir, capture_output=True, text=True)
    if r.returncode != 0:
        die(f"git pull failed: {r.stderr.strip()}")
        return
    print(r.stdout.strip())

    # Auto-migrate if legacy layout detected
    if _detect_legacy_layout():
        print("\nLegacy layout detected — running migration...")
        summary = _run_migration()
        print(f"  Migrated {summary['agents_migrated']} agent(s), {summary['live_sessions']} live session(s) preserved.")
        if summary["projects"]:
            print(f"  Projects: {', '.join(summary['projects'])}")
        print()

    # --clean: hard reinstall with legacy cleanup
    if getattr(args, "clean", False):
        import shutil
        cleaned = []

        # 1. Delete legacy data directories
        legacy_dirs = [
            "/tmp/clawmux-sessions",
            os.path.join(repo_dir, "data"),
        ]
        for d in legacy_dirs:
            if os.path.isdir(d):
                shutil.rmtree(d)
                cleaned.append(f"Removed {d}")

        # Clean stale dot-files from session dirs
        sessions_dir = os.path.join(
            os.environ.get("CLAWMUX_HOME", os.path.expanduser("~/.clawmux")),
            "sessions",
        )
        stale_files = [".session.json", ".project_status.json"]
        if os.path.isdir(sessions_dir):
            for sess in os.scandir(sessions_dir):
                if not sess.is_dir():
                    continue
                for sf in stale_files:
                    p_stale = os.path.join(sess.path, sf)
                    if os.path.exists(p_stale):
                        os.remove(p_stale)
                        cleaned.append(f"Removed {p_stale}")

        # 2. Run migration to ensure ~/.clawmux/ structure
        print("Running migration...")
        summary = _run_migration()
        cleaned.append(f"Migration: {summary['agents_migrated']} agent(s) processed")

        # 3. Reinstall hooks
        print("Reinstalling hooks...")
        _install_hooks(repo_dir)

        # 4. Regenerate CLAUDE.md templates
        print("Regenerating CLAUDE.md templates...")
        try:
            result = http_post("/api/agents/regenerate", {})
            cleaned.append(f"Regenerated {result.get('regenerated', 0)} CLAUDE.md files")
        except SystemExit:
            cleaned.append("Skipped CLAUDE.md regeneration (hub not running)")

        # 5. Print summary
        print("\nClean summary:")
        for item in cleaned:
            print(f"  {item}")
        print()

    # Check system dependencies
    _check_system_deps()

    # Reinstall deps
    venv_pip = os.path.join(repo_dir, ".venv", "bin", "pip")
    if os.path.exists(venv_pip):
        print("Installing dependencies...")
        subprocess.run([venv_pip, "install", "-q", "-r", os.path.join(repo_dir, "requirements.txt")])
    else:
        print("Warning: venv not found, skipping pip install")

    # Reinstall CLI
    cli_src = os.path.join(repo_dir, "clawmux")
    cli_dest = "/usr/local/bin/clawmux"
    if os.path.exists(cli_src):
        venv_python = os.path.join(repo_dir, ".venv", "bin", "python3")
        r = subprocess.run(["sudo", "cp", cli_src, cli_dest], capture_output=True, text=True)
        if r.returncode == 0:
            subprocess.run(["sudo", "chmod", "+x", cli_dest], capture_output=True)
            # Rewrite shebang to venv python
            if os.path.exists(venv_python):
                _rewrite_shebang(cli_dest, venv_python)
            print("CLI updated.")
        else:
            print("Warning: could not update CLI (needs sudo)")

    # Ensure Claude Code hooks are configured
    _install_hooks(repo_dir)

    # Check if hub is running
    hub_running = False
    try:
        http_get("/api/sessions")
        hub_running = True
    except SystemExit:
        pass

    if not hub_running:
        print("Hub is not running. Update complete.")
        return

    if getattr(args, "full", False):
        # Full restart: kill agents + hub, restart everything
        print("Stopping hub and agents...")
        _shutdown_hub("full")
        time.sleep(2)
        result = subprocess.run(["tmux", "list-sessions", "-F", "#{session_name}"],
                               capture_output=True, text=True)
        if result.returncode == 0:
            for name in result.stdout.strip().splitlines():
                if name.startswith("voice-") or name.startswith("clawmux"):
                    subprocess.run(["tmux", "kill-session", "-t", name], capture_output=True)

        for _ in range(10):
            check = subprocess.run(["pgrep", "-f", "python.*hub\\.py"],
                                   capture_output=True, text=True)
            if not check.stdout.strip():
                break
            time.sleep(0.5)

        venv_python = os.path.join(repo_dir, ".venv", "bin", "python")
        hub_py = os.path.join(repo_dir, "server", "hub.py")
        if os.path.exists(venv_python) and os.path.exists(hub_py):
            print("Starting hub...")
            log_file = "/tmp/clawmux.log"
            with open(log_file, "a") as log:
                subprocess.Popen(
                    [venv_python, hub_py],
                    cwd=repo_dir,
                    stdout=log,
                    stderr=log,
                    start_new_session=True,
                )
            for i in range(15):
                time.sleep(1)
                try:
                    http_get("/api/sessions")
                    print("Hub restarted.")
                    break
                except SystemExit:
                    continue
            else:
                print("Warning: hub did not restart within 15 seconds — check /tmp/clawmux.log")
    else:
        # Graceful: reload hub only, agents auto-reconnect
        print("Reloading hub (agents will reconnect)...")
        _shutdown_hub("reload")
        for _ in range(20):
            time.sleep(0.5)
            check = subprocess.run(["pgrep", "-f", "python.*hub\\.py"],
                                   capture_output=True, text=True)
            if not check.stdout.strip():
                break

        venv_python = os.path.join(repo_dir, ".venv", "bin", "python")
        hub_py = os.path.join(repo_dir, "server", "hub.py")
        if os.path.exists(venv_python) and os.path.exists(hub_py):
            log_file = "/tmp/clawmux.log"
            with open(log_file, "a") as log:
                subprocess.Popen(
                    [venv_python, hub_py],
                    cwd=repo_dir,
                    stdout=log,
                    stderr=log,
                    start_new_session=True,
                )
            for i in range(30):
                time.sleep(1)
                try:
                    http_get("/api/sessions")
                    print("Hub reloaded. Agents will reconnect automatically.")
                    break
                except SystemExit:
                    continue
            else:
                print("Warning: hub did not restart within 30 seconds — check /tmp/clawmux.log")

    print("Update complete.")


def _detect_legacy_layout() -> bool:
    """Check if legacy /tmp/clawmux-sessions/ layout exists without ~/.clawmux/."""
    legacy_dir = "/tmp/clawmux-sessions"
    clawmux_home = os.environ.get("CLAWMUX_HOME", os.path.expanduser("~/.clawmux"))
    return os.path.isdir(legacy_dir) and not os.path.isdir(os.path.join(clawmux_home, "data"))


def _run_migration(dry_run: bool = False) -> dict:
    """Migrate from legacy /tmp/clawmux-sessions/ to ~/.clawmux/.

    Returns a summary dict with counts of migrated items.
    """
    import shutil

    legacy_dir = "/tmp/clawmux-sessions"
    clawmux_home = os.environ.get("CLAWMUX_HOME", os.path.expanduser("~/.clawmux"))
    sessions_dir = os.path.join(clawmux_home, "sessions")
    data_dir = os.path.join(clawmux_home, "data")
    history_dir = os.path.join(clawmux_home, "history")

    summary = {
        "agents_found": 0,
        "agents_migrated": 0,
        "live_sessions": 0,
        "projects": set(),
        "history_copied": False,
        "settings_copied": False,
    }

    if not os.path.isdir(legacy_dir):
        print("No legacy layout found at /tmp/clawmux-sessions/")
        return summary

    # Create directory structure
    if not dry_run:
        os.makedirs(sessions_dir, exist_ok=True)
        os.makedirs(data_dir, exist_ok=True)
        os.makedirs(history_dir, exist_ok=True)

    # Scan legacy dirs for .session.json and .project_status.json
    agents_data = {}

    # Check for live tmux sessions
    live_tmux = set()
    try:
        r = subprocess.run(["tmux", "list-sessions", "-F", "#{session_name}"],
                          capture_output=True, text=True)
        if r.returncode == 0:
            live_tmux = set(r.stdout.strip().splitlines())
    except Exception:
        pass

    def _scan_voice_dir(voice_id, dir_path, project_slug=None):
        """Scan a voice directory for session/project state files."""
        session_file = os.path.join(dir_path, ".session.json")
        project_file = os.path.join(dir_path, ".project_status.json")

        if not os.path.exists(session_file):
            return

        summary["agents_found"] += 1
        if project_slug:
            summary["projects"].add(project_slug)

        try:
            session_data = json.loads(open(session_file).read())
        except Exception:
            session_data = {}

        old_session_id = session_data.get("session_id", "")
        is_live = old_session_id in live_tmux
        if is_live:
            summary["live_sessions"] += 1

        agent_entry = {
            "session_id": old_session_id if is_live else None,
            "project": project_slug,
            "role": "worker",
            "area": "",
            "backend": "claude-code",
            "last_active": os.path.getmtime(session_file),
            "model": "opus",
            "state": "idle" if is_live else "dead",
        }

        if os.path.exists(project_file):
            try:
                proj = json.loads(open(project_file).read())
                if not project_slug:
                    agent_entry["project"] = proj.get("project", "")
                agent_entry["area"] = proj.get("area", "")
                if proj.get("project"):
                    summary["projects"].add(proj["project"])
            except Exception:
                pass

        # Handle conflicts: use most recent last_active
        if voice_id not in agents_data or agent_entry["last_active"] > agents_data[voice_id]["last_active"]:
            agents_data[voice_id] = agent_entry
        summary["agents_migrated"] += 1

    # Scan flat layout: /tmp/clawmux-sessions/{voice_id}/
    for entry in os.scandir(legacy_dir):
        if not entry.is_dir():
            continue
        if os.path.exists(os.path.join(entry.path, ".session.json")):
            _scan_voice_dir(entry.name, entry.path)
        else:
            # Project subdir: /tmp/clawmux-sessions/{project}/{voice_id}/
            for sub in os.scandir(entry.path):
                if sub.is_dir() and os.path.exists(os.path.join(sub.path, ".session.json")):
                    _scan_voice_dir(sub.name, sub.path, project_slug=entry.name)

    # Copy history
    repo_dir = _find_repo_dir()
    old_history = os.path.join(repo_dir, "data", "history")
    if os.path.isdir(old_history):
        if not dry_run:
            for f in os.listdir(old_history):
                src = os.path.join(old_history, f)
                dst = os.path.join(history_dir, f)
                if os.path.isfile(src) and not os.path.exists(dst):
                    shutil.copy2(src, dst)
        summary["history_copied"] = True

    # Copy settings
    old_settings = os.path.join(repo_dir, "data", "settings.json")
    new_settings = os.path.join(data_dir, "settings.json")
    if os.path.exists(old_settings) and not os.path.exists(new_settings):
        if not dry_run:
            shutil.copy2(old_settings, new_settings)
        summary["settings_copied"] = True

    # Write agents.json (atomic)
    agents_json_path = os.path.join(data_dir, "agents.json")
    if not dry_run:
        agents_json = {"agents": agents_data, "projects": {}}
        # Merge with existing agents.json if present (don't overwrite newer entries)
        if os.path.exists(agents_json_path):
            try:
                existing = json.loads(open(agents_json_path).read())
                for vid, entry in existing.get("agents", {}).items():
                    if vid not in agents_data or entry.get("last_active", 0) > agents_data.get(vid, {}).get("last_active", 0):
                        agents_json["agents"][vid] = entry
                agents_json["projects"] = existing.get("projects", {})
            except Exception:
                pass
        tmp_path = agents_json_path + ".tmp"
        with open(tmp_path, "w") as f:
            json.dump(agents_json, f, indent=2)
            f.write("\n")
        os.replace(tmp_path, agents_json_path)

    summary["projects"] = list(summary["projects"])
    return summary


def cmd_migrate(args):
    """Migrate from legacy /tmp/clawmux-sessions/ to ~/.clawmux/."""
    dry_run = getattr(args, "dry_run", False)

    if dry_run:
        print("DRY RUN — no files will be modified\n")

    if not _detect_legacy_layout() and not getattr(args, "force", False):
        print("No migration needed — already using ~/.clawmux/ layout.")
        return

    summary = _run_migration(dry_run=dry_run)

    print(f"\nMigration {'preview' if dry_run else 'complete'}:")
    print(f"  Agents found:    {summary['agents_found']}")
    print(f"  Agents migrated: {summary['agents_migrated']}")
    print(f"  Live sessions:   {summary['live_sessions']} (left untouched)")
    if summary["projects"]:
        print(f"  Projects:        {', '.join(summary['projects'])}")
    print(f"  History copied:  {'yes' if summary['history_copied'] else 'no'}")
    print(f"  Settings copied: {'yes' if summary['settings_copied'] else 'no'}")

    if summary["live_sessions"] > 0:
        print(f"\n  NOTE: {summary['live_sessions']} live session(s) preserved at old paths.")
        print("  They will continue working. New sessions will use ~/.clawmux/sessions/.")


def cmd_uninstall(args):
    """Uninstall ClawMux — stop hub, remove CLI, data, and repo."""
    if not args.yes:
        answer = input("This will remove ClawMux (hub, CLI, data, repo). Continue? [y/N] ")
        if answer.lower() not in ("y", "yes"):
            print("Cancelled.")
            return

    # Stop hub
    print("Stopping hub...")
    try:
        import httpx
        httpx.post(f"{HUB_BASE}/api/shutdown", json={"mode": "full"}, timeout=5)
        time.sleep(2)
    except Exception:
        pass

    # Kill tmux sessions
    result = subprocess.run(["tmux", "list-sessions", "-F", "#{session_name}"],
                           capture_output=True, text=True)
    if result.returncode == 0:
        for name in result.stdout.strip().splitlines():
            if name.startswith("voice-") or name.startswith("clawmux"):
                subprocess.run(["tmux", "kill-session", "-t", name], capture_output=True)

    # Remove CLI
    cli_dest = "/usr/local/bin/clawmux"
    if os.path.exists(cli_dest):
        subprocess.run(["sudo", "rm", cli_dest], capture_output=True)
        print("CLI removed.")

    # Remove data
    data_dir = os.path.expanduser("~/.clawmux")
    if os.path.isdir(data_dir):
        import shutil
        shutil.rmtree(data_dir)
        print(f"Data removed ({data_dir}).")

    # Find and remove repo
    try:
        repo_dir = _find_repo_dir()
    except SystemExit:
        repo_dir = None

    if repo_dir and os.path.isdir(repo_dir):
        import shutil
        shutil.rmtree(repo_dir)
        print(f"Repo removed ({repo_dir}).")

    print("ClawMux uninstalled.")


def _shutdown_hub(mode: str = "reload") -> bool:
    """Ask hub to shut down via API. Returns True if request was sent."""
    import urllib.request, urllib.error
    try:
        body = json.dumps({"mode": mode}).encode()
        req = urllib.request.Request(
            hub_url("/api/shutdown"),
            data=body,
            headers={"Content-Type": "application/json"},
        )
        with urllib.request.urlopen(req, timeout=10) as resp:
            resp.read()
        return True
    except (urllib.error.HTTPError, urllib.error.URLError):
        # Endpoint doesn't exist (old hub) or hub not reachable — fall back to SIGTERM
        return False
    except Exception:
        return False


def _sigterm_hub():
    """Fall back to SIGTERM for hubs without /api/shutdown."""
    result = subprocess.run(["pgrep", "-f", "python.*hub\\.py"], capture_output=True, text=True)
    pids = [p for p in result.stdout.strip().split("\n") if p]
    for pid in pids:
        try:
            os.kill(int(pid), signal.SIGTERM)
        except ProcessLookupError:
            pass
    return bool(pids)


def cmd_reload(args):
    """Reload the hub (graceful restart, keeps sessions alive)."""
    if not _shutdown_hub("reload"):
        if not _sigterm_hub():
            die("hub is not running — use 'clawmux start' first")

    print("Reloading hub...")

    # Wait for shutdown
    for _ in range(20):
        time.sleep(0.5)
        check = subprocess.run(
            ["pgrep", "-f", "python.*hub\\.py"],
            capture_output=True, text=True,
        )
        if not check.stdout.strip():
            break

    # Start it back up
    hub_dir = _find_repo_dir()
    venv_python = os.path.join(hub_dir, ".venv", "bin", "python")
    hub_py = os.path.join(hub_dir, "server", "hub.py")
    log_file = "/tmp/clawmux.log"

    with open(log_file, "a") as log:
        subprocess.Popen(
            [venv_python, hub_py],
            cwd=hub_dir,
            stdout=log,
            stderr=log,
            start_new_session=True,
        )

    # Wait for hub to come up
    for i in range(30):
        time.sleep(1)
        try:
            http_get("/api/sessions")
            print("Hub reloaded.")
            return
        except SystemExit:
            continue

    die("hub did not restart within 30 seconds — check /tmp/clawmux.log")


