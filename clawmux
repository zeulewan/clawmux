def die(msg: str) -> None:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def hub_url(path: str) -> str:
    return f"{HUB_BASE}{path}"


def require_session_id() -> str:
    if not SESSION_ID:
        die("CLAWMUX_SESSION_ID not set")
    return SESSION_ID



def _install_hooks(repo_dir: str) -> None:
    """Ensure Claude Code hooks are configured in ~/.claude/settings.json."""
    settings_path = os.path.join(os.path.expanduser("~"), ".claude", "settings.json")
    os.makedirs(os.path.dirname(settings_path), exist_ok=True)
    try:
        with open(settings_path) as f:
            data = json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        data = {}

    hook_entry = {"hooks": [{
        "type": "http",
        "url": f"http://localhost:{HUB_PORT}/api/hooks/tool-status",
        "timeout": 5,
        "headers": {"ClawMux-Session": "$CLAWMUX_SESSION_ID"},
        "allowedEnvVars": ["CLAWMUX_SESSION_ID"],
    }]}
    stop_entry = {"hooks": [{
        "type": "command",
        "command": os.path.join(repo_dir, "hooks", "stop-check-inbox.sh"),
        "timeout": 10,
        "allowedEnvVars": ["CLAWMUX_SESSION_ID", "CLAWMUX_PORT"],
    }]}

    data["hooks"] = {
        "PreToolUse": [hook_entry],
        "PostToolUse": [hook_entry],
        "PostToolUseFailure": [hook_entry],
        "PreCompact": [hook_entry],
        "Stop": [stop_entry],
    }

    with open(settings_path, "w") as f:
        json.dump(data, f, indent=2)
    print("Hooks configured.")


def _rewrite_shebang(filepath: str, python_path: str) -> None:
    """Rewrite the shebang line of a file (cross-platform, no sed)."""
    import tempfile
    try:
        with open(filepath, "r") as f:
            lines = f.readlines()
        if lines:
            lines[0] = f"#!{python_path}\n"
        tmp = tempfile.NamedTemporaryFile(mode="w", delete=False, suffix=".tmp")
        tmp.writelines(lines)
        tmp.close()
        subprocess.run(["sudo", "cp", tmp.name, filepath], capture_output=True)
        subprocess.run(["sudo", "chmod", "+x", filepath], capture_output=True)
        os.unlink(tmp.name)
    except Exception as e:
        print(f"Warning: could not rewrite shebang: {e}")


def http_get(path: str) -> dict:
    """Simple HTTP GET to the hub REST API."""
    import urllib.request
    import urllib.error
    try:
        req = urllib.request.Request(hub_url(path))
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read())
    except urllib.error.URLError as e:
        die(f"cannot reach hub at {HUB_BASE}: {e.reason}")
    except Exception as e:
        die(f"http error: {e}")


def http_post(path: str, data: dict, headers: dict = None) -> dict:
    """Simple HTTP POST to the hub REST API."""
    import urllib.request
    import urllib.error
    try:
        body = json.dumps(data).encode()
        req_headers = {"Content-Type": "application/json"}
        if headers:
            req_headers.update(headers)
        req = urllib.request.Request(
            hub_url(path),
            data=body,
            headers=req_headers,
        )
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        err = json.loads(e.read()) if e.headers.get("content-type", "").startswith("application/json") else {}
        die(err.get("error", f"HTTP {e.code}: {e.reason}"))
    except urllib.error.URLError as e:
        die(f"cannot reach hub at {HUB_BASE}: {e.reason}")
    except Exception as e:
        die(f"http error: {e}")


def http_delete(path: str) -> dict:
    """Simple HTTP DELETE to the hub REST API."""
    import urllib.request
    import urllib.error
    try:
        req = urllib.request.Request(hub_url(path), method="DELETE")
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        err = json.loads(e.read()) if e.headers.get("content-type", "").startswith("application/json") else {}
        die(err.get("error", f"HTTP {e.code}: {e.reason}"))
    except urllib.error.URLError as e:
        die(f"cannot reach hub at {HUB_BASE}: {e.reason}")
    except Exception as e:
        die(f"http error: {e}")


