def set_agent_colors(agent):
    voice = agent.get("voice", "")
    color = COLORS.get(voice)
    if not color:
        return
    target = agent["tmux_session"]
    label = agent.get("label", target)
    fg = "colour16" if voice in LIGHT_BG_VOICES else "colour231"
    for opt, val in [
        ("status-style", f"fg={{fg}},bg={{color}},bold"),
        ("status-left", f" {{label}} "),
        ("status-left-style", f"fg={{fg}},bg={{color}},bold"),
        ("status-left-length", "20"),
        ("status-right", ""),
        ("status-right-length", "0"),
        ("window-status-current-format", ""),
        ("window-status-format", ""),
    ]:
        tmux("set-option", "-t", target, opt, val)

