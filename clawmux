def main():
    parser = argparse.ArgumentParser(
        prog="clawmux",
        description="ClawMux CLI — voice and inter-agent messaging",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""commands:
  Hub Management:
    start       Start the ClawMux hub
    stop        Stop the ClawMux hub
    reload      Restart the hub (agents auto-reconnect)
    status      Show hub state and session info
    projects    List all projects

  Messaging:
    send        Send a message to an agent or user (TTS)
    wait        Block until a message arrives (idle mode)
    messages    List inter-agent messages

  Monitoring:
    monitor     Open tiled tmux view of agent sessions (per project)

  Session:
    spawn       Launch a new agent session
    kill        Kill a single agent session
    project     Set project status in sidebar

  System:
    version     Show version and commit
    update      Update to latest version
    regenerate  Regenerate CLAUDE.md templates
    uninstall   Remove ClawMux

examples:
    clawmux status
    clawmux status sky
    clawmux projects
    clawmux send --to user "Hello, what should I work on?"
    clawmux send --to alloy "Check the auth module"
    clawmux wait
    clawmux start
    clawmux reload
    clawmux monitor
    clawmux monitor --agents sky adam echo""",
    )
    sub = parser.add_subparsers(dest="command", required=False)

    # version
    p = sub.add_parser("version", help="Show ClawMux version and commit")
    p.set_defaults(func=cmd_version)

    # wait (NEW — push-based idle mode)
    p = sub.add_parser("wait", help="Block until a message arrives",
                       description="Enter idle mode. Blocks until an inbox message arrives, then prints it to stdout.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux wait                     # Block until message arrives
    text=$(clawmux wait)             # Capture message text""")
    p.set_defaults(func=cmd_wait)

    # send
    p = sub.add_parser("send", help="Send a message to an agent or user",
                       description="Send a message to another agent or to the user. Use --to user for TTS output.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux send --to alloy "FYI, I pushed a fix."
    clawmux send --to user "Here's what I found."
    clawmux send --to alloy --re msg-abc123 "Got it, thanks." """)
    p.add_argument("--to", required=True, help="Recipient: agent name (e.g. sky, echo) or 'user' for TTS")
    p.add_argument("message", nargs="?", default="", help="Message text (optional with --re for bare acknowledgment)")
    p.add_argument("--re", help="Parent message ID for threaded reply (e.g. msg-abc123)")
    p.add_argument("--from", dest="sender_override", metavar="NAME",
                   help="Override sender identity (for external senders without CLAWMUX_SESSION_ID)")
    p.add_argument("--via", metavar="SYSTEM",
                   help="Deliver via external system (e.g. openclaw) — logs outbound + delivers")
    p.set_defaults(func=cmd_send)

    # status
    p = sub.add_parser("status", help="Show hub state and session info",
                       description="Show hub overview or detailed info for a specific agent.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux status              # Hub overview with all sessions
    clawmux status sky          # Detailed info for Sky""")
    p.add_argument("agent", nargs="?", help="Agent name for detailed status (e.g. sky, alloy)")
    p.add_argument("-w", "--watch", action="store_true", help="Live-updating status (refreshes every 0.5s)")
    p.set_defaults(func=cmd_status)

    # projects
    p = sub.add_parser("projects", help="List all projects",
                       description="Show all configured projects with agent counts.")
    p.set_defaults(func=cmd_projects)

    # start
    p = sub.add_parser("start", help="Start the ClawMux hub",
                       description="Launch the hub process. Exits if hub is already running.")
    p.set_defaults(func=cmd_start)

    # stop
    p = sub.add_parser("stop", help="Stop the ClawMux hub",
                       description="Gracefully stop the hub. Agent tmux sessions are preserved.")
    p.set_defaults(func=cmd_stop)

    # reload
    p = sub.add_parser("reload", help="Restart the hub (agents auto-reconnect)",
                       description="Stop and restart the hub. Active agent sessions reconnect automatically.")
    p.set_defaults(func=cmd_reload)

    # spawn
    p = sub.add_parser("spawn", help="Spawn a new agent session",
                       description="Launch a new agent session via the hub.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux spawn --voice am_echo
    clawmux spawn --voice af_sky
    clawmux spawn --voice am_echo --label "Echo Agent" """)
    p.add_argument("--voice", help="TTS voice (e.g. af_sky, am_echo, am_onyx)")
    p.add_argument("--label", help="Custom label for the session")
    p.set_defaults(func=cmd_spawn)

    # monitor
    p = sub.add_parser("monitor", help="Open tiled tmux view of agent sessions",
                       description="Create a tmux session with tiled panes showing agent sessions. Optionally specify a project slug to monitor only that project's agents.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux monitor                          # Monitor default project agents
    clawmux monitor hnapp                    # Monitor hnapp project agents
    clawmux monitor --agents sky adam echo   # Monitor specific agents
    clawmux monitor --detach                 # Create without attaching
    clawmux monitor --restart                # Kill existing and recreate
    clawmux monitor --no-live                # Static snapshot, no auto-update""")
    p.add_argument("project", nargs="?", help="Project slug to monitor (default: default project)")
    p.add_argument("--agents", nargs="*", help="Specific agent names to monitor (default: all)")
    p.add_argument("--detach", action="store_true", help="Create session without attaching")
    p.add_argument("--restart", action="store_true", help="Kill existing monitor and recreate")
    p.add_argument("--no-live", action="store_true", help="Disable auto-update when agents join/leave")
    p.set_defaults(func=cmd_monitor)

    # kill
    p = sub.add_parser("kill", help="Kill a single agent session",
                       description="Kill an agent session. Default is graceful (API + tmux). Use --force to skip the API call.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux kill echo
    clawmux kill sky --force""")
    p.add_argument("agent", help="Agent name (e.g. sky, echo, fable)")
    p.add_argument("--force", action="store_true", help="Skip graceful API shutdown, just kill tmux")
    p.set_defaults(func=cmd_kill)

    # kill-all
    p = sub.add_parser("kill-all", help="Stop hub and kill all agent sessions",
                       description="Stop the hub AND kill all voice-* tmux sessions. Use for full teardown.")
    p.set_defaults(func=cmd_kill_all)

    # update
    p = sub.add_parser("update", help="Update ClawMux to latest version",
                       description="Pull latest code, reinstall deps, and reinstall CLI. Does NOT restart the hub by default.")
    p.add_argument("--restart", action="store_true", help="Reload hub after updating (default: no restart)")
    p.add_argument("--full", action="store_true", help="Kill all agents and restart everything")
    p.add_argument("--clean", action="store_true", help="Hard reinstall: clean legacy files, reinstall hooks, regenerate templates")
    p.set_defaults(func=cmd_update)

    # migrate
    p = sub.add_parser("migrate", help="Migrate from legacy layout to ~/.clawmux/",
                       description="Migrate session data from /tmp/clawmux-sessions/ to ~/.clawmux/. Live sessions are preserved.")
    p.add_argument("--dry-run", action="store_true", help="Preview migration without making changes")
    p.add_argument("--force", action="store_true", help="Run migration even if ~/.clawmux/ already exists")
    p.set_defaults(func=cmd_migrate)

    # uninstall
    p = sub.add_parser("uninstall", help="Uninstall ClawMux",
                       description="Stop hub, remove CLI, data, and repo. Prompts for confirmation.")
    p.add_argument("--yes", action="store_true", help="Skip confirmation prompt")
    p.set_defaults(func=cmd_uninstall)

    # messages
    p = sub.add_parser("messages", help="List inter-agent messages",
                       description="Show message history between agents.")
    p.add_argument("--session", help="Filter by session ID")
    p.set_defaults(func=cmd_messages)

    # search
    p = sub.add_parser("search", help="Search across agent conversation histories",
                       description="Search all agent histories for messages matching a query. Supports regex.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux search "auth bug"
    clawmux search "deploy" --agent af_sky
    clawmux search "error" --role assistant --limit 20
    clawmux search "API.*endpoint" --after 2025-03-01""")
    p.add_argument("query", help="Search query (supports regex)")
    p.add_argument("--agent", help="Filter by agent voice ID (e.g. af_sky, am_echo)")
    p.add_argument("--role", help="Filter by message role (user, assistant, system, activity)")
    p.add_argument("--after", help="Only messages after this date/timestamp (YYYY-MM-DD or unix ts)")
    p.add_argument("--before", help="Only messages before this date/timestamp (YYYY-MM-DD or unix ts)")
    p.add_argument("--limit", type=int, default=50, help="Max results (default: 50, max: 200)")
    p.add_argument("-C", "--context", type=int, default=0, help="Show N messages before and after each match (like grep -C)")
    p.set_defaults(func=cmd_search)

    # regenerate
    p = sub.add_parser("regenerate", help="Regenerate CLAUDE.md templates",
                       description="Regenerate CLAUDE.md files from template for active agents.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux regenerate              # Regenerate all
    clawmux regenerate am_echo      # Regenerate one agent""")
    p.add_argument("agent", nargs="?", help="Voice ID to regenerate (default: all)")
    p.set_defaults(func=cmd_regenerate)

    # project
    p = sub.add_parser("project", help="Set project status in sidebar",
                       description="Update the sidebar to show what project and area you're working on.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux project voice-hub
    clawmux project voice-hub --area frontend""")
    p.add_argument("project", help="Project or repo name")
    p.add_argument("--area", help="Sub-area (e.g. frontend, backend, docs)")
    p.add_argument("--role", help="Agent role (e.g. Frontend, Backend)")
    p.add_argument("--task", help="Current task description")
    p.set_defaults(func=cmd_project)

    # task
    p = sub.add_parser("task", help="Set current task description",
                       description="Update the sidebar to show what you're currently working on.",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux task 'Fixing auth bug'
    clawmux task 'Reviewing PR #42'""")
    p.add_argument("description", help="Short task description")
    p.set_defaults(func=cmd_task)

    # role
    p = sub.add_parser("role", help="Set agent role",
                       description="Set or change your agent role (shown in the sidebar).",
                       formatter_class=argparse.RawDescriptionHelpFormatter,
                       epilog="""examples:
    clawmux role Frontend
    clawmux role OpenClaw""")
    p.add_argument("role", help="Role name")
    p.set_defaults(func=cmd_role)

    args = parser.parse_args()
    if not args.command:
