{
  "_comment": "Kokoro TTS pronunciation overrides. 'overrides' = exact word replacements (case-insensitive). 'patterns' = regex substitutions (applied in order).",
  "overrides": {
    "JSON": "jason",
    "UUID": "U U I D",
    "HTTPS": "H T T P S",
    "HTTP": "H T T P",
    "ANSI": "an see",
    "kwargs": "keyword args",
    "stdin": "standard in",
    "stdout": "standard out",
    "stderr": "standard error",
    "ClawMux": "Claw Mux",
    "clawmux": "Claw Mux",
    "msg_id": "message I D",
    "msg_ids": "message I Ds",
    "regex": "reg ex"
  },
  "patterns": [
    { "find": "\\bmacOS\\b", "replace": "mac O S", "_comment": "macOS — must come before OS pattern" },
    { "find": "(?<![a-zA-Z])OS(?![a-zA-Z])", "replace": "O S", "_comment": "OS (uppercase only, standalone)" },
    { "find": "\\b([A-Z])([0-9]+)\\b", "replace": "\\1 \\2", "_comment": "V1 → V 1, G1 → G 1" },
    { "find": "([a-zA-Z])([0-9]+)\\b", "replace": "\\1 \\2", "_comment": "word2 → word 2" },
    { "find": "→", "replace": " to ", "_comment": "arrow right" },
    { "find": "←", "replace": " from ", "_comment": "arrow left" },
    { "find": "(\\d+)\\.(\\d+)\\.(\\d+)", "replace": "\\1 dot \\2 dot \\3", "_comment": "version numbers" },
    { "find": "(\\d+)/(\\d+)/(\\d+)", "replace": "\\1 slash \\2 slash \\3", "_comment": "dates with slashes" },
    { "find": "(\\d+)-(\\d+)", "replace": "\\1 to \\2", "_comment": "number ranges" }
  ]
}
