{
    "_comment": "Kokoro TTS pronunciation overrides. 'overrides' = exact word replacements (case-insensitive). 'patterns' = regex substitutions (applied in order).",
    "overrides": {
        "JSON": "jason",
        "UUID": "U U I D",
        "HTTPS": "H T T P S",
        "HTTP": "H T T P",
        "ANSI": "an see",
        "kwargs": "keyword args",
        "stdin": "standard in",
        "stdout": "standard out",
        "stderr": "standard error",
        "ClawMux": "Claw Mux",
        "clawmux": "Claw Mux",
        "msg_id": "message I D",
        "msg_ids": "message I Ds",
        "regex": "reg ex"
    },
    "patterns": [
        {"find": "\\bmacOS\\b", "replace": "mac O S", "_comment": "macOS — must come before OS pattern"},
        {"find": "(?<![a-zA-Z])OS(?![a-zA-Z])", "replace": "O S", "_comment": "OS (uppercase only, standalone)"},
        {"find": "\\b([A-Z])([0-9]+)\\b", "replace": "\\1 \\2", "_comment": "V1 → V 1, G1 → G 1"},
        {"find": "([a-zA-Z])([0-9]+)\\b", "replace": "\\1 \\2", "_comment": "word2 → word 2: separate trailing digits from words"},
        {"find": "→", "replace": " to ", "_comment": "→ reads as 'to'"},
        {"find": "←", "replace": " from ", "_comment": "← reads as 'from'"},
        {"find": "\\bsetSinkId\\b", "replace": "set sink I D", "_comment": "camelCase API method"},
        {"find": "\\bgetUserMedia\\b", "replace": "get user media", "_comment": "camelCase API method"},
        {"find": "(\\d+)\\.(\\d+)\\.(\\d+)", "replace": "\\1 dot \\2 dot \\3", "_comment": "Version/date numbers: 2026.3.2 → 2026 dot 3 dot 2"},
        {"find": "(\\d+)/(\\d+)/(\\d+)", "replace": "\\1 slash \\2 slash \\3", "_comment": "Dates with slashes: 3/7/2026"},
        {"find": "(\\d+)-(\\d+)", "replace": "\\1 to \\2", "_comment": "Number ranges: 1-10 → 1 to 10"},
        {"find": "\\|", "replace": " pipe ", "_comment": "Pipe symbol"},
        {"find": "\\{", "replace": " open brace ", "_comment": "Left curly brace"},
        {"find": "\\}", "replace": " close brace ", "_comment": "Right curly brace"},
        {"find": "\\[", "replace": " open bracket ", "_comment": "Left bracket"},
        {"find": "\\]", "replace": " close bracket ", "_comment": "Right bracket"},
        {"find": "(?<![\\w])\\*(?![\\w])", "replace": " star ", "_comment": "Standalone asterisk"},
        {"find": "~", "replace": " tilde ", "_comment": "Tilde"},
        {"find": "_", "replace": " ", "_comment": "Underscores to spaces: apply_status_bar → apply status bar"}
    ]
}
